-- ════════════════════════════════════════════════════════════════

function Compkiller:_Animation(instance: Instance, tweenInfo: TweenInfo, properties: {[string]: any})
    if not instance or not instance.Parent then
        return
    end
    
    local tween = Services.TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    
    return tween
end

function Compkiller:_FastAnimation(instance: Instance, properties: {[string]: any})
    return self:_Animation(
        instance,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        properties
    )
end

function Compkiller:_SmoothAnimation(instance: Instance, properties: {[string]: any}, duration: number?)
    duration = duration or 0.3
    return self:_Animation(
        instance,
        TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut),
        properties
    )
end

function Compkiller:_SpringAnimation(instance: Instance, properties: {[string]: any})
    return self:_Animation(
        instance,
        TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        properties
    )
end

