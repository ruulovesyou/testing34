function Compkiller:_GetIcon(iconName: string)
    -- Check cache first
    if self.IconCache[iconName] then
        return self.IconCache[iconName]
    end
    
    -- Icon mapping logic here
    local iconId = "rbxassetid://" .. iconName
    self.IconCache[iconName] = iconId
    
    return iconId
end

function Compkiller:_PreloadIcons(iconList: {string})
    for _, iconName in ipairs(iconList) do
        self:_GetIcon(iconName)
    end
end

function Compkiller:CustomIconHighlight()
    self.CustomHighlightMode = true
end

