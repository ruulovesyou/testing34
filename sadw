function Compkiller:Notify(config: Notify)
    config = self:__CONFIG(config, {
        Icon = self.Logo or "",
        Title = "Notification",
        Content = "Content",
        Duration = 3
    })
    
    -- Create notification system if not exists
    if not self.NOTIFY_CACHE then
        self:_InitializeNotificationSystem()
    end
    
    return self.NOTIFY_CACHE.new(config)
end

