-- SECTION 12: CONFIG MANAGEMENT
-- ════════════════════════════════════════════════════════════════

function Compkiller:CreateConfigManager(directory: string)
    local ConfigManager = {
        Directory = directory or "Compkiller/Configs",
        
        WriteConfig = function(self, config: WriteConfig)
            -- Save config to file
            local configData = {
                Name = config.Name,
                Author = config.Author,
                CreatedDate = os.date("%Y-%m-%d %H:%M:%S"),
                Flags = Compkiller.Flags
            }
            
            local success = pcall(function()
                writefile(
                    self.Directory .. "/" .. config.Name .. ".json",
                    Services.HttpService:JSONEncode(configData)
                )
            end)
            
            return success
        end,
        
        LoadConfig = function(self, configName: string)
            local success, result = pcall(function()
                local data = readfile(self.Directory .. "/" .. configName .. ".json")
                return Services.HttpService:JSONDecode(data)
            end)
            
            if success and result then
                -- Apply flags
                for flag, value in pairs(result.Flags or {}) do
                    Compkiller.Flags[flag] = value
                end
                return true
            end
            
            return false
        end,
        
        DeleteConfig = function(self, configName: string)
            local success = pcall(function()
                delfile(self.Directory .. "/" .. configName .. ".json")
            end)
            return success
        end,
        
        GetConfigs = function(self)
            local configs = {}
            local success = pcall(function()
                local files = listfiles(self.Directory)
                for _, file in ipairs(files) do
                    if file:match("%.json$") then
                        table.insert(configs, file:match("([^/\\]+)%.json$"))
                    end
                end
            end)
            
            return configs
        end,
        
        GetConfigCount = function(self)
            return #self:GetConfigs()
        end,
        
        ReadInfo = function(self, configName: string)
            local success, result = pcall(function()
                local data = readfile(self.Directory .. "/" .. configName .. ".json")
                return Services.HttpService:JSONDecode(data)
            end)
            
            if success then
                return {
                    Name = result.Name,
                    Author = result.Author,
                    CreatedDate = result.CreatedDate
                }
            end
            
            return nil
        end
    }
    
    return ConfigManager
end

