        Dark = {
            Highlight = Color3.fromRGB(100, 150, 255),
            SwitchColor = Color3.fromRGB(255, 255, 255),
            BGDBColor = Color3.fromRGB(20, 20, 20),
        },
        Light = {
            Highlight = Color3.fromRGB(70, 120, 235),
            SwitchColor = Color3.fromRGB(0, 0, 0),
            BGDBColor = Color3.fromRGB(240, 240, 240),
        },
    }
    
    if themes[themeName] then
        self.Colors = themes[themeName]
    end
end

function Compkiller:SetHighlightColor(color: Color3)
    self.Colors.Highlight = color
end

