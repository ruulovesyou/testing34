--- String Utilities ---

function Compkiller:_RandomString(length: number?)
    length = length or 16
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local result = {}
    
    for i = 1, length do
        local rand = math.random(1, #chars)
        table.insert(result, chars:sub(rand, rand))
    end
    
    return table.concat(result)
end

function Compkiller:_CleanString(str: string)
    return str:gsub("%s+", " "):match("^%s*(.-)%s*$")
end

--- Table Utilities ---

function Compkiller:__CONFIG(provided: {[any]: any}, defaults: {[any]: any})
    provided = provided or {}
    local result = {}
    
    for key, defaultValue in pairs(defaults) do
        result[key] = provided[key] ~= nil and provided[key] or defaultValue
    end
    
    return result
end

function Compkiller:_DeepCopy(original: {[any]: any})
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then
            copy[k] = self:_DeepCopy(v)
        else
            copy[k] = v
        end
    end
    return copy
end

--- Instance Utilities ---

function Compkiller:_FindFirstChild(parent: Instance, name: string, recursive: boolean?)
    if recursive then
        return parent:FindFirstChild(name, true)
    end
    return parent:FindFirstChild(name)
end

function Compkiller:_WaitForChild(parent: Instance, name: string, timeout: number?)
    return parent:WaitForChild(name, timeout or 5)
end

--- Math Utilities ---

function Compkiller:_Clamp(value: number, min: number, max: number)
    return math.max(min, math.min(max, value))
end

function Compkiller:_Round(value: number, decimals: number?)
    decimals = decimals or 0
    local mult = 10 ^ decimals
    return math.floor(value * mult + 0.5) / mult
end

function Compkiller:_Lerp(a: number, b: number, t: number)
    return a + (b - a) * t
end

--- Color Utilities ---

function Compkiller:_ColorToHex(color: Color3)
    return string.format("#%02X%02X%02X", 
        color.R * 255, 
        color.G * 255, 
        color.B * 255
    )
end

function Compkiller:_HexToColor(hex: string)
    hex = hex:gsub("#", "")
    return Color3.fromRGB(
        tonumber(hex:sub(1, 2), 16),
        tonumber(hex:sub(3, 4), 16),
        tonumber(hex:sub(5, 6), 16)
    )
end

