function Compkiller:AddButton(section: any, config: Button)
    config = self:__CONFIG(config, {
        Name = "Button",
        Callback = function() end
    })
    
    local ButtonObject = {
        Name = config.Name,
        
        Click = function(self)
            pcall(config.Callback)
        end,
        
        SetText = function(self, text: string)
            self.Name = text
            -- Update UI text
        end,
        
        SetCallback = function(self, callback: () -> any?)
            config.Callback = callback
        end
    }
    
    table.insert(section.Elements, ButtonObject)
    return ButtonObject
end

--- Toggle Element ---

function Compkiller:AddToggle(section: any, config: Toggle)
    config = self:__CONFIG(config, {
        Name = "Toggle",
        Default = false,
        Flag = nil,
        Risky = false,
        Callback = function(value) end
    })
    
    local state = config.Default
    
    local ToggleObject = {
        Name = config.Name,
        State = state,
        
        SetValue = function(self, value: boolean)
            self.State = value
            state = value
            
            -- Update UI
            -- Store in flags if provided
            if config.Flag then
                Compkiller.Flags[config.Flag] = value
            end
            
            pcall(config.Callback, value)
        end,
        
        Toggle = function(self)
            self:SetValue(not self.State)
        end,
        
        GetValue = function(self)
            return self.State
        end
    }
    
    -- Initialize
    if config.Flag then
        Compkiller.Flags[config.Flag] = state
    end
    
    table.insert(section.Elements, ToggleObject)
    return ToggleObject
end

--- Slider Element ---

function Compkiller:AddSlider(section: any, config: Slider)
    config = self:__CONFIG(config, {
        Name = "Slider",
        Min = 0,
        Max = 100,
        Default = 50,
        Type = "Normal",
        Round = 1,
        Callback = function(value) end
    })
    
    local value = config.Default
    
    local SliderObject = {
        Name = config.Name,
        Value = value,
        
        SetValue = function(self, newValue: number)
            newValue = self:_ClampValue(newValue)
            newValue = Compkiller:_Round(newValue, config.Round)
            
            self.Value = newValue
            value = newValue
            
            -- Update UI
            pcall(config.Callback, newValue)
        end,
        
        GetValue = function(self)
            return self.Value
        end,
        
        _ClampValue = function(self, val: number)
            return Compkiller:_Clamp(val, config.Min, config.Max)
        end
    }
    
    table.insert(section.Elements, SliderObject)
    return SliderObject
end

--- Dropdown Element ---

function Compkiller:AddDropdown(section: any, config: Dropdown)
    config = self:__CONFIG(config, {
        Name = "Dropdown",
        Default = "",
        Values = {},
        Multi = false,
        Callback = function(value) end
    })
    
    local selected = config.Multi and {} or config.Default
    
    local DropdownObject = {
        Name = config.Name,
        Selected = selected,
        Values = config.Values,
        
        SetValue = function(self, value: string | {string})
            if config.Multi then
                self.Selected = value
            else
                self.Selected = value
            end
            
            -- Update UI
            pcall(config.Callback, value)
        end,
        
        GetValue = function(self)
            return self.Selected
        end,
        
        UpdateValues = function(self, newValues: {string})
            self.Values = newValues
            -- Update dropdown options
        end,
        
        Clear = function(self)
            if config.Multi then
                self.Selected = {}
            else
                self.Selected = ""
            end
        end
    }
    
    table.insert(section.Elements, DropdownObject)
    return DropdownObject
end

--- TextBox Element ---

function Compkiller:AddTextBox(section: any, config: TextBoxConfig)
    config = self:__CONFIG(config, {
        Name = "TextBox",
        Default = "",
        Placeholder = "Enter text...",
        Flag = nil,
        Numeric = false,
        Callback = function(text) end
    })
    
    local text = config.Default
    
    local TextBoxObject = {
        Name = config.Name,
        Text = text,
        
        SetValue = function(self, newText: string)
            if config.Numeric then
                newText = tonumber(newText) and tostring(tonumber(newText)) or self.Text
            end
            
            self.Text = newText
            text = newText
            
            -- Update UI
            if config.Flag then
                Compkiller.Flags[config.Flag] = newText
            end
            
            pcall(config.Callback, newText)
        end,
        
        GetValue = function(self)
            return self.Text
        end,
        
        Clear = function(self)
            self:SetValue("")
        end
    }
    
    table.insert(section.Elements, TextBoxObject)
    return TextBoxObject
end

--- ColorPicker Element ---

function Compkiller:AddColorPicker(section: any, config: ColorPicker)
    config = self:__CONFIG(config, {
        Name = "Color Picker",
        Default = Color3.fromRGB(255, 255, 255),
        Flag = nil,
        Transparency = 0,
        Callback = function(color, trans) end
    })
    
    local color = config.Default
    local transparency = config.Transparency
    
    local ColorPickerObject = {
        Name = config.Name,
        Color = color,
        Transparency = transparency,
        
        SetValue = function(self, newColor: Color3, newTrans: number?)
            self.Color = newColor
            color = newColor
            
            if newTrans then
                self.Transparency = newTrans
                transparency = newTrans
            end
            
            -- Update UI
            if config.Flag then
                Compkiller.Flags[config.Flag] = {Color = newColor, Transparency = self.Transparency}
            end
            
            pcall(config.Callback, newColor, self.Transparency)
        end,
        
        GetValue = function(self)
            return self.Color, self.Transparency
        end
    }
    
    table.insert(section.Elements, ColorPickerObject)
    return ColorPickerObject
end

--- Keybind Element ---

function Compkiller:AddKeybind(section: any, config: Keybind)
    config = self:__CONFIG(config, {
        Name = "Keybind",
        Default = Enum.KeyCode.E,
        Callback = function(key) end,
        Blacklist = {}
    })
    
    local key = config.Default
    
    local KeybindObject = {
        Name = config.Name,
        Key = key,
        
        SetValue = function(self, newKey: Enum.KeyCode | string)
            -- Check blacklist
            for _, blacklisted in ipairs(config.Blacklist) do
                if blacklisted == newKey then
                    return
                end
            end
            
            self.Key = newKey
            key = newKey
            
            -- Update UI
            pcall(config.Callback, newKey)
        end,
        
        GetValue = function(self)
            return self.Key
        end
    }
    
    table.insert(section.Elements, KeybindObject)
    return KeybindObject
end

