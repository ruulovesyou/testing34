-- RunExecutorIntegrityTest -- 5 probes from darkdex to validate executor
-- Detects: fake unpack, bad game cache, missing namecall support,
--          broken setfenv/getfenv, and mocked wait() implementations
-- Returns a report table: { passed, failed, results{} }
do
	local _INTEGRITY_REPORT = nil

	local _PROBES = {
		-- Probe 1: Cyclic table unpack -- hooked/fake unpack fails this
		{
			name = "cyclic_unpack",
			desc = "Cyclic table unpack (detects hooked unpack)",
			fn   = function()
				local t  = {}
				t[1]     = t
				local x  = ((table.unpack or unpack) or unpack)(t)
				assert(x and x[1] == t, "cyclic unpack mismatch")
			end,
		},
		-- Probe 2: game == workspace.Parent cache -- detects broken instance cache
		{
			name = "game_cache",
			desc = "game == workspace.Parent identity (detects broken instance cache)",
			fn   = function()
				assert(game == workspace.Parent, "game/workspace cache broken")
			end,
		},
		-- Probe 3: newproxy + __namecall -- detects executors that can't handle userdata metamethods
		{
			name = "newproxy_namecall",
			desc = "newproxy __namecall support (detects broken userdata metamethods)",
			fn   = function()
				assert(_type(newproxy) == "function", "newproxy missing")
				local obj    = newproxy(true)
				local mt     = getmetatable(obj)
				local called = false
				mt.__namecall = function() called = true end
				mt.__index    = function() end
				_pcall(function(...) obj:TestCall() end)
				assert(called, "__namecall was not invoked")
			end,
		},
		-- Probe 4: getfenv(2) propagation -- detects broken setfenv/getfenv sandboxing
		{
			name = "getfenv_propagation",
			desc = "getfenv(2) env propagation (detects broken setfenv/getfenv)",
			fn   = function()
				assert(_type(getfenv) == "function", "getfenv missing")
				assert(_type(setfenv) == "function", "setfenv missing")
				local sentinel = { __ck_probe = true }
				local env      = setmetatable({ __ck_probe = true }, { __index = getfenv() })
				local testFn   = function()
					assert(getfenv(2).__ck_probe == true, "getfenv(2) propagation broken")
				end
				setfenv(testFn, env)
				testFn()
			end,
		},
		-- Probe 5: wait() timing -- detects mocked wait() that returns instantly (< 0.05s for 0.1s wait)
		{
			name = "wait_timing",
			desc = "wait() timing accuracy (detects mocked wait implementation)",
			fn   = function()
				local start = _tick()
				local ok, _ = _pcall(function(...) task.wait(0.1) end)
				if not ok then _pcall(function(...) wait(0.1) end) end
				local elapsed = _tick() - start
				assert(elapsed >= 0.05, _sfmt("wait() returned in %.4fs -- likely mocked", elapsed))
			end,
		},
	}

	function Compkiller:RunExecutorIntegrityTest()
		local results = {}
		local passed  = 0
		local failed  = 0

		for _, probe in _ipairs(_PROBES) do
			local ok, err = _pcall(probe.fn)
			results[probe.name] = {
				pass  = ok,
				desc  = probe.desc,
				err   = ok and nil or _tostring(err),
			}
			if ok then
				passed = passed + 1
				_CKLog(_sfmt("IntegrityProbe [[ok]] %s", probe.name))
			else
				failed = failed + 1
				warn(_sfmt("[CK:Integrity] [x] %s -- %s", probe.name, _tostring(err)))
			end
		end

		_INTEGRITY_REPORT = {
			passed    = passed,
			failed    = failed,
			total     = passed + failed,
			safe      = (failed == 0),
			results   = results,
			testedAt  = _tick(),
		}

		_CKLog(_sfmt("IntegrityTest: %d/%d passed -- executor %s.",
			passed, passed + failed,
			failed == 0 and "appears CLEAN" or "has SUSPICIOUS traits"))

		return _INTEGRITY_REPORT
	end

	function Compkiller:GetIntegrityReport()
		if not _INTEGRITY_REPORT then
			return self:RunExecutorIntegrityTest()
		end
		return _INTEGRITY_REPORT
	end
end


