		"rbxassetid://10734941499",
		Compkiller.Logo,
	};

	if Compkiller.SecureMode then
		for i,v in next , RequiredAssets do task.wait()
			pcall(function(...)
				Compkiller:CacheImage(v);
			end);
		end;
	else
