	local function enableAdvancedOptimizations(enabled)
		_OPT.Enabled = (enabled == true)
		if _OPT.Enabled then
			if not _OPT.MonitorThread then
				local thread
				thread = task.spawn(function(...)
					while _OPT.Enabled and _OPT.MonitorThread == thread do
						task.wait(_OPT.MemInterval)
						if _OPT.Enabled and _OPT.MonitorThread == thread then
							Compkiller:_SweepMemory()
						end
					end
					if _OPT.MonitorThread == thread then
						_OPT.MonitorThread = nil
					end
				end)
				_OPT.MonitorThread = thread
				_TrackThread(thread)
			end
		else
			_OPT.MonitorThread = nil
		end
		_CKLog("AdvancedOptimizations: " .. (_OPT.Enabled and "ON" or "OFF") .. " | Threshold=" .. _OPT.AnimThreshold .. "fps" .. " | MemInterval=" .. _OPT.MemInterval .. "s")
		return _OPT.Enabled
	end

