	-- ========================================================================
	local function setSafeCall(enabled)
		_SAFE_CALL_ENABLED = (enabled == true)
		_CKLog("SetSafeCall: " .. (_SAFE_CALL_ENABLED and "ON" or "OFF"))
	end

	local function safeExec(fn, onError)
		if _type(fn) ~= "function" then
			_CKLog("SafeExec: argument must be a function, got " .. _type(fn))
			return false, "invalid argument"
		end
		local ok, err = _xpcall(fn, function(e)
			local tb = ""
			_pcall(function(...) tb = debug and debug.traceback and debug.traceback(_tostring(e), 2) or "" end)
			return _tostring(e) .. (tb ~= "" and ("\n" .. tb) or "")
		end)
		if not ok then
			_CKLog("SafeExec caught error: " .. _tostring(err))
			if _type(onError) == "function" then
				_pcall(onError, err)
			end
		end
		return ok, ok and nil or _tostring(err)
	end

	local function safeCall(fn, ...)
		if not _SAFE_CALL_ENABLED then
			return fn(...)
		end
		local args = {...}
		local ok, result = pcall(function(...) return fn((table.unpack or unpack)(args)) end)
		if not ok then
			table.insert(_SANDBOX_ERRORS, { time = tick(), err = tostring(result) })
			_CKLog("SafeCall caught: " .. tostring(result))
		end
		return ok, result
	end

	local function wrap(fn, onError)
		if _type(fn) ~= "function" then return fn end
		return _newcclosure(function(...)
			return safeExec(function() return fn(...) end, onError)
		end)
	end

	local function newSandbox(cfg)
		cfg = cfg or {}
		local _MAX_ERRORS  = cfg.maxErrors or 10
		local _errorCount  = 0
		local _disabled    = false
		local _errorLog    = {}

		local sandbox = {}

		function sandbox:Run(fn, ...)
			if _disabled then
				_CKLog("Sandbox: disabled after too many errors.")
				return false, "sandbox disabled"
			end
			if _type(fn) ~= "function" then return false, "not a function" end
			local args = {...}
			local ok, err = _xpcall(function(...) return fn(_unpack(args)) end, function(e)
				return _tostring(e)
			end)
			if not ok then
				_errorCount = _errorCount + 1
				_tinsert(_errorLog, { time = _tick(), err = err })
				_CKLog(_sfmt("Sandbox: error #%d -- %s", _errorCount, err))
				if _errorCount >= _MAX_ERRORS then
					_disabled = true
					warn("[CK:Sandbox] Too many errors -- sandbox disabled.")
				end
			end
			return ok, ok and nil or err
		end

		function sandbox:GetErrors()  return _errorLog  end
		function sandbox:GetCount()   return _errorCount end
		function sandbox:IsDisabled() return _disabled   end
		function sandbox:Reset()
			_errorCount = 0
			_disabled   = false
			_errorLog   = {}
			_CKLog("Sandbox: reset.")
		end

		return sandbox
	end

