        _CONTENT_NC_HOOK = hookmetamethod(game, "__namecall", _newcclosure(function(self, instances, ...)
            if _checkcaller() then return _CONTENT_NC_HOOK(self, instances, ...) end
            local m = _getnamecallmethod()
            if (m == "PreloadAsync" or m == "preloadAsync") and _type(instances) == "table" then
                if instances[1] == _CoreGuiSvc or instances[1] == game then
