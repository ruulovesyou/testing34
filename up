	local function enableMemorySpoof(enabled)
		if enabled == false then
			_MEMSPOOFED = false
			_GCSPOOFED  = false
			_CKLog("MemorySpoof: disabled (note: hooks persist until restart).")
			return
		end
		if _MEMSPOOFED and _GCSPOOFED then
			_CKLog("MemorySpoof: already active.")
			return
		end

		local Stats = _pcall(function(...) return cloneref(game:GetService("Stats")) end)
		if not Stats then Stats = game:GetService("Stats") end

		-- GcInfo cosine spoof
		if not _GCSPOOFED and _type(hookfunction) == "function" and _type(getrenv) == "function" then
			_pcall(function(...)
				-- Wait for gcinfo to peak so our baseline is accurate
				local maxima = 0
				local waited = 0
				while waited < 60 do
					local gc = gcinfo()
					if gc >= maxima then maxima = gc else break end
					task.wait(0.05)
					waited = waited + 1
				end
				task.wait(0.3)

				local baseGC   = gcinfo() + 200
				local getGC    = _makeCosineSpoof(baseGC, 200)
				local renv     = getrenv()

				local _oldGc;   _oldGc  = hookfunction(renv.gcinfo, _newcclosure(function(...)
					return getGC()
				end))
				local _oldCg;   _oldCg  = hookfunction(renv.collectgarbage, _newcclosure(function(arg, ...)
					if not _checkcaller() and arg == "count" then
						return getGC()
					end
					local ok, r = _pcall(_oldCg, arg, ...)
					return ok and r or getGC()
				end))

				_GCSPOOFED = true
				_CKLog("MemorySpoof: gcinfo/collectgarbage cosine spoof active.")
			end)
		end

		-- Stats:GetTotalMemoryUsageMb spoof
		if not _MEMSPOOFED and _type(hookmetamethod) == "function" then
			_pcall(function(...)
				local baseMem = Stats:GetTotalMemoryUsageMb()
				local rand    = 0
				_TrackConn(RunService.Stepped:Connect(function()
					rand = Random.new():NextNumber(-10, 10)
				end))
				local function getMem() return baseMem + rand end

				-- __namecall intercept
				local _oldMemNC;  _oldMemNC = hookmetamethod(game, "__namecall", _newcclosure(function(self, ...)
					if not _checkcaller() then
						local m = _getnamecallmethod()
						if _type(self) == "userdata" and
						(m == "GetTotalMemoryUsageMb" or m == "getTotalMemoryUsageMb") then
							return getMem()
						end
						if _type(self) == "userdata" and
						(m == "GetMemoryUsageMbForTag" or m == "getMemoryUsageMbForTag") then
							local tagRand = Random.new():NextNumber(-0.1, 0.1)
							local baseTag = _pcall(function(...) return Stats:GetMemoryUsageMbForTag(Enum.DeveloperMemoryTag.Gui) end) or 0
							return (type(baseTag) == "number" and baseTag or 0) + tagRand
						end
					end
					return _oldMemNC(self, ...)
				end))

				-- Direct hookfunction on indexed method
				local _oldMemF;  _oldMemF = hookfunction(Stats.GetTotalMemoryUsageMb, _newcclosure(function(self, ...)
					if not _checkcaller() then return getMem() end
					return _oldMemF(self, ...)
				end))

				_MEMSPOOFED = true
				_CKLog("MemorySpoof: GetTotalMemoryUsageMb + GetMemoryUsageMbForTag spoofed.")
			end)
		end
	end

	local function enableContentProviderBypass(enabled)
		if enabled == false then
			_CPBYPASS_ACTIVE = false
			_CKLog("ContentProviderBypass: disabled.")
			return
		end
		if _CPBYPASS_ACTIVE then return end
		if _type(hookmetamethod) ~= "function" then
			_CKLog("ContentProviderBypass: hookmetamethod unavailable -- skipped.")
			return
		end

		_pcall(function(...)
			local ContentRef = cloneref(game:GetService("ContentProvider"))
			local CoreGuiRef = cloneref(game:GetService("CoreGui"))
			local safePool   = _buildAssetPool()

			-- __namecall intercept
			local _oldCP; _oldCP = hookmetamethod(game, "__namecall", _newcclosure(function(self, instances, ...)
				local method = _getnamecallmethod()
				if not _checkcaller()
				and (method == "PreloadAsync" or method == "preloadAsync")
				and _type(self) == "userdata" then
					-- If AC is scanning CoreGui or game root -- feed safe shuffled list
					if _type(instances) == "table"
					and (instances[1] == CoreGuiRef or instances[1] == game) then
						local safeList = _shuffleTable({(table.unpack or unpack)(safePool)})
						return _oldCP(self, safeList, ...)
					end
				end
				return _oldCP(self, instances, ...)
			end))

			-- hookfunction on indexed PreloadAsync too
			local _oldCPF; _oldCPF = hookfunction(ContentRef.PreloadAsync, _newcclosure(function(self, instances, callback)
				if not _checkcaller() and _type(instances) == "table" then
					if instances[1] == CoreGuiRef or instances[1] == game then
						local safeList = _shuffleTable({(table.unpack or unpack)(safePool)})
						return _oldCPF(self, safeList, callback)
					end
				end
				return _oldCPF(self, instances, callback)
			end))

			_CPBYPASS_ACTIVE = true
			_CKLog(_sfmt("ContentProviderBypass: active -- %d safe assets in pool.", #safePool))
		end)
	end

	local function enableHoneypotBypass(enabled)
		if enabled == false then
			_HONEYPOT_ACTIVE  = false
			_PROXY_STRONGHOLD = {}
			_CKLog("HoneypotBypass: disabled.")
			return
		end
		if _HONEYPOT_ACTIVE then return end
		if _type(hookfunction) ~= "function" or _type(getrenv) ~= "function" then
			_CKLog("HoneypotBypass: hookfunction/getrenv unavailable -- skipped.")
			return
		end

		_pcall(function(...)
			local renv = getrenv()

			-- Hook newproxy -- every proxy created by any script goes into our stronghold
			local _oldProxy; _oldProxy = hookfunction(renv.newproxy, _newcclosure(function(...)
				local proxy = _oldProxy(...)
				_tinsert(_PROXY_STRONGHOLD, proxy)
				return proxy
			end))

			-- Also periodically scrub nil entries to prevent memory bloat
			-- (entries only become nil if we explicitly remove them -- since they're strong refs, they won't GC naturally)
			_ckSpawn(function(...)
				while _HONEYPOT_ACTIVE do
					task.wait(30)
					local clean = {}
					for _, v in _ipairs(_PROXY_STRONGHOLD) do
						if v ~= nil then _tinsert(clean, v) end
					end
					_PROXY_STRONGHOLD = clean
				end
			end)

			-- Additional: hook setmetatable to detect and neutralize honeypot tables
			-- If AC makes a weak-mode table containing CoreGui, swap __mode to "" (strong)
			local _oldSMT; _oldSMT = hookfunction(renv.setmetatable, _newcclosure(function(t, mt)
				if not _checkcaller() and _type(mt) == "table" then
					local mode = _rawget(mt, "__mode")
					if mode and (mode:find("v") or mode:find("k")) then
						-- Check if this table contains CoreGui -- if so it's a honeypot
						if _type(t) == "table" then
							for _, v in _ipairs(t) do
								if v == game:GetService("CoreGui") then
									-- Neutralize: remove weak mode so entries never GC
									local safeMt = {}
									for k, val in _pairs(mt) do safeMt[k] = val end
									safeMt["__mode"] = ""
									_CKLog("HoneypotBypass: neutralized CoreGui weak-table trap.")
									return _oldSMT(t, safeMt)
								end
							end
						end
					end
				end
				return _oldSMT(t, mt)
			end))

			_HONEYPOT_ACTIVE = true
			_CKLog("HoneypotBypass: newproxy stronghold + setmetatable guard active.")
		end)
	end

	local function enableScanGuard(screenGui, enabled)
		if enabled == false then
			_SCANGUARD_ACTIVE = false
			_CKLog("ScanGuard: disabled.")
			return
		end
		if _SCANGUARD_ACTIVE then return end
		if _type(hookmetamethod) ~= "function" then
			_CKLog("ScanGuard: hookmetamethod unavailable -- skipped.")
			return
		end

		_pcall(function(...)
			local _oldSG; _oldSG = hookmetamethod(game, "__namecall", _newcclosure(function(self, ...)
				if _checkcaller() then return _oldSG(self, ...) end
				local method = _getnamecallmethod()

				-- Filter GetDescendants -- remove our ScreenGui from returned table
				if method == "GetDescendants" or method == "GetChildren" then
					local results = {_oldSG(self, ...)}
					if _type(results[1]) == "table" then
						local filtered = {}
						for _, v in _ipairs(results[1]) do
							-- Hide our GUI and anything inside it
							local isOurs = false
							if screenGui and (v == screenGui or _pcall(function(...)
								return v:IsDescendantOf(screenGui)
							end) == true) then
								isOurs = true
							end
							if not isOurs then _tinsert(filtered, v) end
						end
						return filtered
					end
					return (table.unpack or unpack)(results)
				end

				-- Block DescendantAdded connections that fire on our GUI
				-- We can't stop the event but we can filter the callback's argument
				if (method == "Connect" or method == "connect") and self then
					_pcall(function(...)
						-- Check if self is CoreGui.DescendantAdded or similar signal
						-- We wrap the passed callback to filter out our GUI
						local args = {...}
						if _type(args[1]) == "function" then
							local origCb = args[1]
							args[1] = _newcclosure(function(obj)
								-- If the added obj IS or IS INSIDE our screengui, swallow it
								if screenGui and obj then
									if obj == screenGui then return end
									local ok, desc = _pcall(function(...)
										return obj:IsDescendantOf(screenGui)
									end)
									if ok and desc then return end
								end
								origCb(obj)
							end)
							return _oldSG(self, (table.unpack or unpack)(args))
						end
					end)
				end

				return _oldSG(self, ...)
			end))

			_SCANGUARD_ACTIVE = true
			_CKLog("ScanGuard: GetDescendants/DescendantAdded filter active.")
		end)
	end

	local function enableNamecallGuard(enabled)
		if enabled == false then
			_NCGUARD_ACTIVE = false
			_CKLog("NamecallGuard: disabled.")
			return
		end
		if _NCGUARD_ACTIVE then return end
		if _type(_getrawmetatable) ~= "function" then
			_CKLog("NamecallGuard: getrawmetatable unavailable -- skipped.")
			return
		end

		_pcall(function(...)
			local mt = _getrawmetatable(game)
			if not mt then return end

			-- Snapshot what our current __namecall is
			_NC_OUR_HOOK = mt.__namecall

			-- Poll every 0.5s -- if AC replaced __namecall, reinstall ours on top
			_ckSpawn(function(...)
				while _NCGUARD_ACTIVE do
					task.wait(0.5)
					_pcall(function(...)
						local current = _rawget(mt, "__namecall")
						if current ~= _NC_OUR_HOOK and _islclosure(current) then
							-- AC replaced it with a Lua spy -- layer ours back on top
							local acSpy = current
							_setreadonly(mt, false)
							mt.__namecall = _newcclosure(function(self, ...)
								-- Call AC's spy but make it think it's an executor call
								-- (we do NOT call acSpy -- we swallow it and call our original)
								_CKLog("NamecallGuard: AC __namecall spy intercepted and neutralized.")
								return _NC_OUR_HOOK(self, ...)
							end)
							_setreadonly(mt, true)
							_CKLog("NamecallGuard: __namecall restored over AC spy.")
						end
					end)
				end
			end)

			_NCGUARD_ACTIVE = true
			_CKLog("NamecallGuard: __namecall tamper watch active (polling every 0.5s).")
		end)
	end

	local function enableExecutorCloaker(enabled)
		if enabled == false then
			_CLOAKER_ACTIVE = false
			_CKLog("ExecutorCloaker: disabled (hooks persist until restart).")
			return
		end
		if _CLOAKER_ACTIVE then return end

		_pcall(function(...)
			local renv = getrenv and getrenv() or nil

			-- Hook rawget -- intercept _G lookups for executor globals
			if _type(hookfunction) == "function" then
				local _oldRawget; _oldRawget = hookfunction(
					getrenv and getrenv().rawget or rawget,
					_newcclosure(function(t, k)
						if not _checkcaller() and t == _G and _EXEC_SET[k] then
							_CKLog("ExecutorCloaker: blocked rawget(_G, '" .. _tostring(k) .. "')")
							return nil
						end
						return _oldRawget(t, k)
					end)
				)

				-- Also cloak getrenv() gethui check (AntiCheat.txt line: getrenv().gethui)
				if renv and _type(renv) == "table" then
					local _oldGetrenv; _oldGetrenv = hookfunction(getrenv, _newcclosure(function(...)
						if not _checkcaller() then
							-- Return a proxy table that hides all executor globals
							local realEnv = _oldGetrenv(...)
							return setmetatable({}, {
								__index = _newcclosure(function(_, k)
									if _EXEC_SET[k] then
										_CKLog("ExecutorCloaker: getrenv()." .. _tostring(k) .. " hidden.")
										return nil
									end
									return realEnv[k]
								end),
								__newindex = _newcclosure(function(_, k, v)
									realEnv[k] = v
								end),
							})
						end
						return _oldGetrenv(...)
					end))
				end
			end

			_CLOAKER_ACTIVE = true
			_CKLog(_sfmt("ExecutorCloaker: active -- %d globals cloaked.", #_EXEC_GLOBALS))
		end)
	end


	-- ========================================================================
	-- BYPASS ENGINE -- bulk
	-- ========================================================================
	local function enableAllBypasses()
		_ckSpawn(function(...)
			task.wait(1)  -- wait for game to fully load so baselines are accurate
			enableGCBypass(true)
			enableMemoryBypass(true)
			enableContentBypass(true)
			enableHoneyPotBypass(true)
			enableGlobalScanBypass(true)
			enableMetaGuard(true)
			enableRenvBypass(true)
			enableTextBoxBypass(true)
			_CKLog("AllBypasses: all 8 bypass systems active.")
		end)
	end

	local function disableAllBypasses()
		enableGCBypass(false)
		enableMemoryBypass(false)
		enableContentBypass(false)
		enableHoneyPotBypass(false)
		enableGlobalScanBypass(false)
		enableMetaGuard(false)
		enableRenvBypass(false)
		enableTextBoxBypass(false)
		_CKLog("AllBypasses: all systems disabled.")
	end

	local function armAntiDetection(cfg)
		cfg = cfg or {}
		local sg = cfg.screenGui  -- pass the ScreenGui reference for ScanGuard

		if cfg.memorySpoof       ~= false then enableMemorySpoof(true)             end
		if cfg.contentBypass     ~= false then enableContentProviderBypass(true)   end
		if cfg.honeypotBypass    ~= false then enableHoneypotBypass(true)          end
		if cfg.scanGuard         ~= false then enableScanGuard(sg, true)           end
		if cfg.namecallGuard     ~= false then enableNamecallGuard(true)           end
		if cfg.executorCloaker   ~= false then enableExecutorCloaker(true)         end

		_CKLog("ArmAntiDetection: all requested bypasses armed.")
	end


	-- ========================================================================
	-- PRESETS
	-- ========================================================================
	-- MC.preset("stealth"/"performance"/"balanced"/"secure"/"nuke")
	-- MC.preset("nuke", { gcBypass=false }) -> nuke with selective overrides
	local function preset(name, overrides)
		local p = {}
		p.stealth = function()
			setPerformanceProfile("LOW")
			setSmartAnimations(false)
			enableAdvancedOptimizations(false)
			setSleepMode(true)
			enableNameObfuscation(true)
			_CKLog("Preset.stealth: active")
		end
		p.performance = function()
			setPerformanceProfile("HIGH")
			setSmartAnimations(true)
			enableAdvancedOptimizations(true)
			setSleepMode(false)
			startRenderManager()
			_CKLog("Preset.performance: active")
		end
		p.balanced = function()
			setPerformanceProfile("MEDIUM")
			setSmartAnimations(true)
			enableAdvancedOptimizations(true)
			setSleepMode(false)
			_CKLog("Preset.balanced: active")
		end
		p.secure = function()
			enableNameObfuscation(true)
			startAnomalyDetector(5)
			enableAntiAFK(true)
			enableAntiKick(true)
			setSafeCall(true)
			_CKLog("Preset.secure: active")
		end
		p.nuke = function()
			setPerformanceProfile("HIGH")
			setSmartAnimations(true)
			enableAdvancedOptimizations(true)
			enableNameObfuscation(true)
			startAnomalyDetector(5)
			enableAntiAFK(true)
			enableAntiKick(true)
			setSafeCall(true)
			enableAllBypasses()
			if type(overrides) == "table" then
				task.defer(function(...)
					local map = {
						gcBypass         = function(v) enableGCBypass(v)          end,
						memBypass        = function(v) enableMemoryBypass(v)       end,
						contentBypass    = function(v) enableContentBypass(v)      end,
						honeyPotBypass   = function(v) enableHoneyPotBypass(v)     end,
						globalScanBypass = function(v) enableGlobalScanBypass(v)   end,
						metaGuard        = function(v) enableMetaGuard(v)          end,
						renvBypass       = function(v) enableRenvBypass(v)         end,
						textBoxBypass    = function(v) enableTextBoxBypass(v)      end,
					}
					for k, fn in pairs(map) do
						if overrides[k] == false then _pcall(fn, false) end
					end
				end)
			end
			_CKLog("Preset.nuke: ALL systems armed.")
		end
		local fn = p[tostring(name):lower()]
		if fn then fn()
		else warn("[CK] MasterControl.preset: unknown '" .. tostring(name) ..
			"' -- valid: stealth  performance  balanced  secure  nuke") end
	end


	-- ========================================================================
	-- APPLY -- fire everything from one config table
	-- ========================================================================
	local function apply(cfg)
		if type(cfg) ~= "table" then return end

		-- DEBUG
		if cfg.debug            ~= nil  then setDebug(cfg.debug)                                             end
		if cfg.dumpStats        == true then dumpStats()                                                     end

		-- PERFORMANCE
		if cfg.performance      ~= nil  then
			if cfg.performance == true  then setPerformanceProfile("HIGH")
			elseif cfg.performance == false then setPerformanceProfile("LOW")
			else setPerformanceProfile(tostring(cfg.performance):upper()) end
		end
		if cfg.tier             ~= nil  then
			if cfg.tier == true  then setHardwareTier("HIGH")
			elseif cfg.tier == false then setHardwareTier("LOW")
			else setHardwareTier(tostring(cfg.tier):upper()) end
		end
		if cfg.animThreshold    ~= nil  then setAnimThreshold(cfg.animThreshold)                             end
		if cfg.memInterval      ~= nil  then setMemInterval(cfg.memInterval)                                 end
		if cfg.smartAnimations  ~= nil  then setSmartAnimations(cfg.smartAnimations)                         end
		if cfg.advancedOpt      ~= nil  then enableAdvancedOptimizations(cfg.advancedOpt)                    end
		if cfg.optimizeMode     ~= nil  then optimizeMode(cfg.optimizeMode)                                  end
		if cfg.sleepMode        ~= nil  then setSleepMode(cfg.sleepMode)                                     end
		if cfg.fpsCap           ~= nil  then fpsCap(cfg.fpsCap)                                              end

		-- ANIMATIONS
		if cfg.pauseAnimations  == true  then pauseAllAnimations()                                           end
		if cfg.pauseAnimations  == false then resumeAllAnimations()                                          end
		if cfg.forceGC          == true  then forceGC()                                                      end
		if cfg.cleanupAll       == true  then cleanupAll()                                                   end

		-- RENDER
		if cfg.renderManager    == true  then startRenderManager()                                           end
		if cfg.renderManager    == false then stopRenderManager()                                            end
		if cfg.renderCull       == true  then renderCull()                                                   end
		if cfg.renderCull       == false then renderResume()                                                 end

		-- SANDBOX
		if cfg.safeCall         ~= nil  then setSafeCall(cfg.safeCall)                                       end

		-- GUI SHIELD
		if cfg.obfuscate        ~= nil  then enableNameObfuscation(cfg.obfuscate)                            end
		if cfg.hardReset        == true then hardReset()                                                     end
		if cfg.indexHook        == true then indexHook()                                                     end
		if cfg.turboScramble    ~= nil and cfg.turboScrambleGui then
			enableTurboScramble(cfg.turboScrambleGui, cfg.turboScramble)
		end

		-- WINDOW POSITION
		if cfg.savePosition     ~= nil  then saveWindowPosition(cfg.savePosition)                            end
		if cfg.loadPosition     == true then loadWindowPosition()                                            end

		-- ANOMALY
		if cfg.anomalyWatch     == true  then startAnomalyDetector(_nv(cfg.anomalyInterval, 5))              end
		if cfg.anomalyWatch     == false then stopAnomalyDetector()                                          end
		if cfg.anomalyCallback  ~= nil  then setAnomalyCallback(cfg.anomalyCallback)                        end

		-- SECURITY
		if cfg.antiKick         ~= nil  then enableAntiKick(cfg.antiKick)                                    end
		if cfg.antiAfk          ~= nil  then enableAntiAFK(cfg.antiAfk)                                      end

		-- BYPASS ENGINE -- bulk first, then individual overrides
		if cfg.allBypasses      == true  then enableAllBypasses()                                            end
		if cfg.allBypasses      == false then disableAllBypasses()                                           end
		if cfg.gcBypass         ~= nil  then enableGCBypass(cfg.gcBypass)                                    end
		if cfg.memBypass        ~= nil  then enableMemoryBypass(cfg.memBypass)                               end
		if cfg.contentBypass    ~= nil  then enableContentBypass(cfg.contentBypass)                          end
		if cfg.honeyPotBypass   ~= nil  then enableHoneyPotBypass(cfg.honeyPotBypass)                        end
		if cfg.globalScanBypass ~= nil  then enableGlobalScanBypass(cfg.globalScanBypass)                    end
		if cfg.metaGuard        ~= nil  then enableMetaGuard(cfg.metaGuard)                                  end
		if cfg.renvBypass       ~= nil  then enableRenvBypass(cfg.renvBypass)                                end
		if cfg.textBoxBypass    ~= nil  then enableTextBoxBypass(cfg.textBoxBypass)                          end
		if cfg.memorySpoof      ~= nil  then enableMemorySpoof(cfg.memorySpoof)                              end
		if cfg.contentProviderBypass ~= nil then enableContentProviderBypass(cfg.contentProviderBypass)      end
		if cfg.honeypotBypass   ~= nil  then enableHoneypotBypass(cfg.honeypotBypass)                        end
		if cfg.scanGuard        ~= nil  then enableScanGuard(cfg.scanGuardGui, cfg.scanGuard)                end
		if cfg.namecallGuard    ~= nil  then enableNamecallGuard(cfg.namecallGuard)                          end
		if cfg.executorCloaker  ~= nil  then enableExecutorCloaker(cfg.executorCloaker)                      end
		if cfg.armAntiDetection ~= nil  then
			armAntiDetection(type(cfg.armAntiDetection) == "table" and cfg.armAntiDetection or {})
		end

		-- DELAYED DIAGNOSTICS (after game settles)
		if cfg.runDiagnostics == true or cfg.integrityTest == true or cfg.anomalyCheck == true then
			_ckSpawn(function(...)
				task.wait(cfg.diagnosticsDelay or 8)
				if cfg.runDiagnostics == true then runDiagnostics()           end
				if cfg.anomalyCheck   == true then runAnomalyCheck()          end
				if cfg.integrityTest  == true then runExecutorIntegrityTest() end
			end)
		end

		-- PRESET runs last so explicit keys take priority
		if cfg.preset then preset(cfg.preset, cfg.presetOverrides) end

		_CKLog("MasterControl.apply: done.")
	end


	-- ========================================================================
	-- RETURN CONTROLLER
	-- Unknown keys -> no-op + warn via __index
