            return
        end
        getgenv()[_CULL_KEY] = _SaveCameraState()
        _SuppressRender()
        _CKLog("RenderCull: 3D suppressed.")
    end

    function Compkiller:RenderResume()
        local state = getgenv()[_CULL_KEY]
        if not state then
            _CKLog("RenderResume: nothing to resume.")
            return
        end
        _RestoreRender(state)
        getgenv()[_CULL_KEY] = nil
        _CKLog("RenderResume: 3D restored.")
    end

    function Compkiller:StartRenderManager()
        self:StopRenderManager()

        local conns = {}

        local c1 = _TrackConn(UserInputService.WindowFocusReleased:Connect(function()
            if not getgenv()[_CULL_KEY] then
                getgenv()[_CULL_KEY] = _SaveCameraState()
            end
            _SuppressRender()
            _CKLog("RenderManager: focus lost -- 3D suppressed, FPS capped.")
        end))
        table.insert(conns, c1)

        local c2 = _TrackConn(UserInputService.WindowFocused:Connect(function()
            local state = getgenv()[_CULL_KEY]
            if state then
                _RestoreRender(state)
                getgenv()[_CULL_KEY] = nil
            end
            _CKLog("RenderManager: focus gained -- 3D restored.")
        end))
        table.insert(conns, c2)

        getgenv()[_RENDER_CONN] = conns
        _CKLog("StartRenderManager: active.")
    end

    function Compkiller:StopRenderManager()
        local state = getgenv()[_CULL_KEY]
        if state then
            _RestoreRender(state)
            getgenv()[_CULL_KEY] = nil
        end
        local conns = getgenv()[_RENDER_CONN]
        if type(conns) == "table" then
            for _, c in ipairs(conns) do
                pcall(function(...) c:Disconnect() end)
            end
        end
        getgenv()[_RENDER_CONN] = nil
        _CKLog("StopRenderManager: stopped, 3D restored.")
    end
end


-- Usage:
do
    local RateLimiter = {}
    RateLimiter.__index = RateLimiter

    function RateLimiter.new(interval)
        local self = setmetatable({
            _interval = math.max(0.05, interval or 0.25),
            _queue    = {},
            _running  = false,
        }, RateLimiter)
        return self
    end

    function RateLimiter:Fire(remote, ...)
        local args = {...}
        table.insert(self._queue, { remote = remote, args = args })
        if not self._running then
            self._running = true
            _ckSpawn(function(...)
                while #self._queue > 0 do
                    local item = table.remove(self._queue, 1)
                    pcall(function(...)
                        item.remote:FireServer((table.unpack or unpack)(item.args))
                    end)
                    task.wait(self._interval)
                end
                self._running = false
            end)
        end
    end

    function RateLimiter:Flush()
        self._queue = {}
        _CKLog("RateLimiter: queue flushed.")
    end

    function Compkiller:NewRateLimiter(interval)
        return RateLimiter.new(interval)
    end
end


do
