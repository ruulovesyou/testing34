        { task,    "cancel",        "task.cancel"      },
    }

    local function _captureBaseline()
        local bl = {}
        for _, w in _ipairs(_WATCH) do
            local ok, val = _pcall(_rawget, w[1], w[2])
            bl[w[3]] = ok and val or nil
        end
        return bl
    end

    -- HOOKFUNCTION DETECTION -- checks if exploit hooked any key functions
    local function _detectHooks()
        local hooked = {}
        local checkFns = {
            { "pcall",        _G.pcall,        _pcall        },
            { "rawget",       _G.rawget,       _rawget       },
            { "rawset",       _G.rawset,       _rawset       },
            { "tostring",     _G.tostring,     _tostring     },
            { "type",         _G.type,         _type         },
        }
        for _, entry in _ipairs(checkFns) do
            if entry[2] ~= entry[3] then
                _tinsert(hooked, entry[1])
            end
        end
        -- Check if hookfunction/hookmetamethod themselves are present (exploit feature)
        if _type(hookfunction)    == "function" then _tinsert(hooked, "hookfunction_present")    end
        if _type(hookmetamethod)  == "function" then _tinsert(hooked, "hookmetamethod_present")  end
        return hooked
    end

    function Compkiller:StartAnomalyDetector(interval)
        if _DETECTOR_THREAD then
            _CKLog("Anomaly: detector already running.")
            return
        end
        interval = _mmax(2, interval or 5)
        _BASELINE = _captureBaseline()
        _CKLog(_sfmt("Anomaly: baseline captured (%d targets), scanning every %ds.",
            #_WATCH, interval))

        _DETECTOR_THREAD = _ckSpawn(function(...)
            while _DETECTOR_THREAD do
                task.wait(interval)
                if not _DETECTOR_THREAD then break end

                local tampered = {}
                for _, w in _ipairs(_WATCH) do
                    local ok, cur = _pcall(_rawget, w[1], w[2])
                    if ok and _BASELINE[w[3]] ~= nil and cur ~= _BASELINE[w[3]] then
                        _tinsert(tampered, w[3])
                    end
                end

                -- Hook detection pass
                local hooked = _detectHooks()
                for _, h in _ipairs(hooked) do
                    _tinsert(tampered, h)
                end

                if #tampered > 0 then
                    warn("[CK:Anomaly] (!) Tampered/Hooked: " .. table.concat(tampered, ", "))
                    if _type(_TAMPER_CALLBACK) == "function" then
                        _pcall(_TAMPER_CALLBACK, tampered)
                    end
                else
                    _CKLog("Anomaly: scan clean.")
                end
            end
        end)
    end

    function Compkiller:StopAnomalyDetector()
        if _DETECTOR_THREAD then
            _pcall(task.cancel, _DETECTOR_THREAD)
            _DETECTOR_THREAD = nil
            _BASELINE        = nil
            _CKLog("Anomaly: detector stopped.")
        end
    end

    -- Set a callback that fires when tampering is detected
    function Compkiller:SetAnomalyCallback(fn)
        -- [PATCH #7] Wrap callback in pcall so a crash cannot kill the detector loop
        if _type(fn) == "function" then
            _TAMPER_CALLBACK = function(...)
                local ok, err = _pcall(fn, ...)
                if not ok then
                    _CKLog("Anomaly: callback error (loop preserved): " .. _tostring(err))
                end
            end
        else
            _TAMPER_CALLBACK = nil
        end
        _CKLog("Anomaly: callback " .. (_TAMPER_CALLBACK and "set (sandboxed)." or "cleared."))
    end
end

