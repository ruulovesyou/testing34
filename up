    -- [BYPASS 3] ContentProvider:PreloadAsync whitelist
    -- Detection: game calls PreloadAsync({CoreGui}) or PreloadAsync({game}) and reads
    --            back which asset IDs came from the GUI scan -- finds exploit GUI assets.
    -- Bypass: when game scans CoreGui or game root, intercept and return a shuffled
    --         table of only safe/whitelisted real Roblox asset IDs instead.
    local _CONTENT_ACTIVE  = false
    local _CONTENT_NC_HOOK = nil
    local _CONTENT_FN_HOOK = nil

    -- Whitelist: only assets Roblox itself would return from a clean CoreGui scan
    local _SAFE_ASSETS = {}
    local _GAME_ASSETS = {}

    local function _BuildAssetWhitelist()
        -- Harvest real assets from CoreGui before any exploit GUI is loaded
        _pcall(function(...)
            _ContentProv:PreloadAsync({_CoreGuiSvc}, function(assetId)
