local function _makeCosineSpoof(baseValue, amplitude)
    local _cos    = math.cos
    local _acos   = math.acos
    local _floor  = math.floor
    local _pi     = math.pi
    local tick_v  = 0

    -- Advance tick on Stepped so the curve animates naturally
    _ckSpawn(function(...)
        _TrackConn(RunService.Stepped:Connect(function()
            local formula = ((_acos(_cos(_pi * tick_v)) / _pi) * (amplitude * 2)) + -amplitude
            local nextF   = ((_acos(_cos(_pi * tick_v + 0.01)) / _pi) * (amplitude * 2)) + -amplitude
            if formula > nextF then
                tick_v = tick_v + 0.07
            else
                tick_v = tick_v + 0.01
            end
        end))
    end)

    return function()
        local formula = ((_acos(_cos(_pi * tick_v)) / _pi) * (amplitude * 2)) + -amplitude
        return _floor(baseValue + formula)
    end
end


