local _HW_TIER      = "MEDIUM"   -- [PATCH #10] default lowered from HIGH -- reduces activity fingerprint on AC idle-detection; nuke preset still overrides to HIGH explicitly
local _HW_FPS_RAW   = 60

do
    -- CONTINUOUS FPS SAMPLER -- rolling 60-frame window, updates every second
    -- On boot: waits for first 60 frames to set initial tier
    -- After: keeps updating _OPT.FPS and adjusts thresholds dynamically
    local _hwSamples  = {}
    local _hwBooted   = false
    local _hwConn

    _hwConn = RunService.Heartbeat:Connect(function(dt)
        _tinsert(_hwSamples, 1 / _mmax(dt, 0.001))
        if #_hwSamples > 60 then _tremove(_hwSamples, 1) end  -- rolling window
        if #_hwSamples < 60 then return end

        local _sum = 0
        for _, v in _ipairs(_hwSamples) do _sum = _sum + v end
        _HW_FPS_RAW   = _sum / #_hwSamples
        local newFPS  = _mfloor(_HW_FPS_RAW + 0.5)

        local newTier
        if _HW_FPS_RAW >= 55 then
            newTier = "HIGH"
        elseif _HW_FPS_RAW >= 35 then
            newTier = "MEDIUM"
        else
            newTier = "LOW"
        end

        -- First boot -- set tier and disconnect the boot phase
        if not _hwBooted then
            _hwBooted  = true
            _HW_TIER   = newTier
            _CKLog(_sfmt("Hardware Tier (boot): %s (avg %.1f fps)", _HW_TIER, _HW_FPS_RAW))
        end

        -- Continuous live update
        if _OPT then
            _OPT.FPS = newFPS
        end

        if Compkiller then
            Compkiller.HardwareFPS = newFPS
            -- Auto-adapt thresholds if tier changed at runtime
            if newTier ~= Compkiller.HardwareTier then
                Compkiller.HardwareTier = newTier
                _HW_TIER = newTier
                if newTier == "LOW" then
                    Compkiller.PerformanceMode = true
                    if _OPT then _OPT.AnimThreshold = 60 end
                    -- Auto quality reduction on LOW
                    _pcall(function(...) game:GetService("Lighting").GlobalShadows = false end)
                    _pcall(function(...) settings().Rendering.QualityLevel = 1 end)
                    _CKLog("Performance: tier dropped to LOW -- shadows off, quality reduced.")
                elseif newTier == "MEDIUM" then
                    Compkiller.PerformanceMode = false
                    if _OPT then _OPT.AnimThreshold = 40 end
                    _CKLog("Performance: tier changed to MEDIUM.")
                else
                    Compkiller.PerformanceMode = false
                    if _OPT then _OPT.AnimThreshold = 30 end
                    _CKLog("Performance: tier changed to HIGH.")
                end
            end
        end
    end)
    _tinsert(_CK_CONNECTIONS, _hwConn)
end

local _GUI_PARENT
local _GUI_SHIELD_METHOD = "PlayerGui"

-- GUI SHIELD -- multi-executor parent detection
-- Priority: hidden_ui fns -> RobloxGui -> CoreGui (elevation-gated) -> PlayerGui
-- Uses _CK_ELEVATED to skip CoreGui probe when privilege is already confirmed
do
    -- Attempt 1: all 4 known hidden UI aliases (expanded from darkdex)
    if not _GUI_PARENT then
        local _huiFns = {
            get_hidden_gui,
            gethui,
            get_hidden_ui,
            hiddenUI,
            syn and syn.get_hidden_gui,
        }
        local _huiNames = {
            "get_hidden_gui", "gethui", "get_hidden_ui", "hiddenUI", "syn.get_hidden_gui"
        }
        for i, fn in _ipairs(_huiFns) do
            if _type(fn) == "function" then
                local ok, result = _pcall(fn)
                if ok and result then
                    _GUI_PARENT        = result
                    _GUI_SHIELD_METHOD = _huiNames[i]
                    break
                end
            end
        end
    end

    -- Attempt 2: RobloxGui inside CoreGui (most hidden hardcoded spot)
    if not _GUI_PARENT then
        local ok, rg = _pcall(function(...)
            return CoreGui:FindFirstChild("RobloxGui")
        end)
        if ok and rg then
            _GUI_PARENT        = rg
            _GUI_SHIELD_METHOD = "RobloxGui"
        end
    end

    -- Attempt 3: CoreGui direct -- only try if we know we're elevated (darkdex pattern)
    -- Avoids erroring/being detected on low-privilege executors
    if not _GUI_PARENT and _CK_ELEVATED then
        _GUI_PARENT        = CoreGui
        _GUI_SHIELD_METHOD = "CoreGui"
    end

    -- Attempt 4: CoreGui probe for executors where elevation wasn't detected
    if not _GUI_PARENT then
        local ok = _pcall(function(...)
            local probe = Instance.new("ScreenGui")
            probe.Parent = CoreGui
            probe:Destroy()
        end)
        if ok then
            _GUI_PARENT        = CoreGui
            _GUI_SHIELD_METHOD = "CoreGui (probed)"
        end
    end

    -- Fallback: PlayerGui
    if not _GUI_PARENT then
        _GUI_PARENT        = PlayerGui
        _GUI_SHIELD_METHOD = "PlayerGui"
    end

    _CKLog(_sfmt("GUI Shield: using '%s' as safe parent.", _GUI_SHIELD_METHOD))
end


-- __INDEX HOOK -- hides ScreenGui from game-side FindFirstChild / index scans
-- Any non-executor attempt to find the GUI by name returns nil
-- Technique taken from CMD X and upgraded with checkcaller() guard
local _CK_HIDDEN_GUI_NAMES = {}   -- all names this GUI has ever had, kept in sync

local function _InstallIndexHook()
    _pcall(function(...)
        local mt       = _getrawmetatable(game)
        if not mt then return end
        local oldIndex = mt.__index
        if not oldIndex then return end

        _setreadonly(mt, false)
        mt.__index = _newcclosure(function(self, key)
            -- Let executor's own calls through untouched
            if _checkcaller() then
                return oldIndex(self, key)
            end
            -- If game-side code is trying to find our GUI by any name it's ever had -> hide it
            for _, hiddenName in _ipairs(_CK_HIDDEN_GUI_NAMES) do
                if key == hiddenName then
                    return nil
                end
            end
            return oldIndex(self, key)
        end)
        _setreadonly(mt, true)
        _CKLog("GuiShield: __index hook installed on game metatable.")
    end)
end

_ckSpawn(_InstallIndexHook)


-- GUI INTEGRITY MONITOR -- re-shields ScreenGui if someone moves/destroys it
local _CK_INTEGRITY_CONNS = {}

local function _StartGuiIntegrityMonitor(screenGui)
    -- Watch Parent -- re-parent immediately if moved
    local conn1 = _pcall(function(...)
        return screenGui:GetPropertyChangedSignal("Parent"):Connect(function()
            if screenGui.Parent ~= _GUI_PARENT then
                _pcall(function(...) screenGui.Parent = _GUI_PARENT end)
                _CKLog("GuiIntegrity: parent tampered -- re-shielded.")
            end
        end)
    end)
    if _type(conn1) ~= "boolean" then
        _tinsert(_CK_INTEGRITY_CONNS, conn1)
        _tinsert(_CK_CONNECTIONS, conn1)
    end

    -- Watch Name -- re-encrypt immediately if renamed externally
    local conn2 = _pcall(function(...)
        return screenGui:GetPropertyChangedSignal("Name"):Connect(function()
            _pcall(function(...)
                local newName = _EncryptGuiName()
                screenGui.Name = newName
                _tinsert(_CK_HIDDEN_GUI_NAMES, newName)
            end)
            _CKLog("GuiIntegrity: name tampered -- re-encrypted.")
        end)
    end)
    if _type(conn2) ~= "boolean" then
        _tinsert(_CK_INTEGRITY_CONNS, conn2)
        _tinsert(_CK_CONNECTIONS, conn2)
    end
    -- Cleanup connections when GUI is destroyed
    local connD = _pcall(function(...)
        return screenGui.Destroying:Connect(function()
            for _, c in _ipairs(_CK_INTEGRITY_CONNS) do _pcall(function(...) c:Disconnect() end) end
            _CK_INTEGRITY_CONNS = {}
        end)
    end)
    if _type(connD) ~= "boolean" then _tinsert(_CK_CONNECTIONS, connD) end
end


