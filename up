local function _ShieldParent(screenGui)
    -- Set max DisplayOrder so game UI can never render on top
    _pcall(function(...) screenGui.DisplayOrder = 2147483647 end)
    _pcall(function(...) screenGui.ResetOnSpawn = false end)

    -- Encrypt name and register it in hidden name pool
    _pcall(function(...)
