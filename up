        _CKLog(_sfmt("ContentBypass: whitelist built -- %d CoreGui, %d game assets.",
            #_SAFE_ASSETS, #_GAME_ASSETS))
    end

    local function _shuffleTable(t)
        local n = #t
        while n > 1 do
            local k = _mrandom(n)
            t[n], t[k] = t[k], t[n]
            n = n - 1
        end
        return t
    end

    local function _EnableContentBypass()
        if _CONTENT_ACTIVE then return end
