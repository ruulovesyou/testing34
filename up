function Compkiller:_SmartAnimation(Self, Info, Property)
    local currentFPS = _OPT.FPS
    local threshold  = _OPT.AnimThreshold

    if currentFPS < threshold then
        for prop, val in pairs(Property) do
            pcall(function(...) Self[prop] = val end)
        end
        _OPT.Stats.InstantSets = _OPT.Stats.InstantSets + 1
        return _OPT._DummyTween
    end


    local baseDuration = (Info and Info.Time) or 0.25
    local fpsScale     = math.clamp(currentFPS / 60, 0.5, 1.0)
    local newDuration  = math.max(0.05, baseDuration * fpsScale)

    local newInfo
    if Info then
        newInfo = TweenInfo.new(
            newDuration,
            Info.EasingStyle,
            Info.EasingDirection,
            Info.RepeatCount,
            Info.Reverses,
            Info.DelayTime
        )
    else
        newInfo = TweenInfo.new(newDuration)
    end

    for prop in pairs(Property) do
        local dedupKey = tostring(Self) .. "|" .. prop
        local existing = _OPT.ActiveTweenMap[dedupKey]
        if existing then
            local ok, playing = pcall(function(...) return existing.PlaybackState end)
            if ok and playing == Enum.PlaybackState.Playing then
                pcall(function(...) existing:Cancel() end)
                _OPT.Stats.DedupCancels = _OPT.Stats.DedupCancels + 1
            end
            _OPT.ActiveTweenMap[dedupKey] = nil
        end
    end

    local tween = TweenService:Create(Self, newInfo, Property)
    table.insert(_OPT.ActiveTweens, tween)
    for prop in pairs(Property) do
        _OPT.ActiveTweenMap[tostring(Self) .. "|" .. prop] = tween
    end
    tween:Play()

    tween.Completed:Connect(function()
        local idx = table.find(_OPT.ActiveTweens, tween)
        if idx then table.remove(_OPT.ActiveTweens, idx) end
        for prop in pairs(Property) do
            local key = tostring(Self) .. "|" .. prop
            if _OPT.ActiveTweenMap[key] == tween then
                _OPT.ActiveTweenMap[key] = nil
            end
        end
    end)

    return tween
end

function Compkiller:_SweepMemory()
    local kept = {}
    for _, tw in ipairs(_OPT.ActiveTweens) do
        local ok, state = pcall(function(...) return tw.PlaybackState end)
        if ok and state == Enum.PlaybackState.Playing then
            table.insert(kept, tw)
        end
    end
    _OPT.ActiveTweens = kept
    _OPT.Stats.MemorySweeps = _OPT.Stats.MemorySweeps + 1
    _OPT.Stats.LastSweepAt  = tick()
end

