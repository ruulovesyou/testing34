function Compkiller:EnableAdvancedOptimizations(enabled)
    _OPT.Enabled = (enabled == true)
    if _OPT.Enabled then
        if not _OPT.MonitorThread then
            local thread
            thread = task.spawn(function(...)
                while _OPT.Enabled and _OPT.MonitorThread == thread do
                    task.wait(_OPT.MemInterval)
                    if _OPT.Enabled and _OPT.MonitorThread == thread then
                        Compkiller:_SweepMemory()
                    end
                end
                if _OPT.MonitorThread == thread then
                    _OPT.MonitorThread = nil
                end
            end)
            _OPT.MonitorThread = thread
            _TrackThread(thread)
        end
    else
        _OPT.MonitorThread = nil
    end
    _CKLog("AdvancedOptimizations: " .. (_OPT.Enabled and "ON" or "OFF") .. " | Threshold=" .. _OPT.AnimThreshold .. "fps" .. " | MemInterval=" .. _OPT.MemInterval .. "s")
    return _OPT.Enabled
end

function Compkiller:CleanupAll()
    local cancelled = 0
    for key, tw in pairs(_OPT.ActiveTweenMap) do
        local ok, playing = pcall(function(...) return tw.PlaybackState end)
        if ok and playing == Enum.PlaybackState.Playing then
            pcall(function(...) tw:Cancel() end)
            cancelled = cancelled + 1
        end
        _OPT.ActiveTweenMap[key] = nil
    end
    for _, tw in ipairs(_OPT.ActiveTweens) do
        local ok, playing = pcall(function(...) return tw.PlaybackState end)
        if ok and playing == Enum.PlaybackState.Playing then
            pcall(function(...) tw:Cancel() end)
            cancelled = cancelled + 1
        end
    end
    _OPT.ActiveTweens = {}
    _OPT.Stats.TweensCancelled = _OPT.Stats.TweensCancelled + cancelled
    Compkiller:_SweepMemory()
    _CKLog("CleanupAll: cancelled " .. cancelled .. " tweens.")
    return cancelled
end

