                                 or  _shuffleTable(table.move(_GAME_ASSETS, 1, #_GAME_ASSETS, 1, {}))
                    return _CONTENT_NC_HOOK(self, safe, ...)
                end
            end
            return _CONTENT_NC_HOOK(self, instances, ...)
        end))

        if _type(hookfunction) == "function" then
            _CONTENT_FN_HOOK = hookfunction(_ContentProv.PreloadAsync, _newcclosure(function(self, tbl, cb)
                if _checkcaller() then return _CONTENT_FN_HOOK(self, tbl, cb) end
