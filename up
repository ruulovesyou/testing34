-- ============================================================================
Compkiller.MasterControl = function()

	-- value coercion helpers
	local function _bv(v, d) if v == nil then return d ~= false end return v ~= false and v ~= "false" end
	local function _sv(v, d) return type(v) == "string" and v or (d or "") end
	local function _nv(v, d) return type(v) == "number" and v or (d or 0) end

	-- fpsCap (executor native, not a Compkiller method)
	local function fpsCap(v)
		_pcall(function(...) setfpscap(_nv(v, 60)) end)
	end

	-- indexHook (uses local _InstallIndexHook)
	local function indexHook()
		_InstallIndexHook()
	end


	-- ========================================================================
	-- DEBUG
	-- ========================================================================
	local function setDebug(enabled)
		Compkiller.Debug = (enabled == true)
		_CK_DEBUG  = Compkiller.Debug   -- sync boot flag too
		_CKLog("Debug logging " .. (Compkiller.Debug and "ENABLED" or "DISABLED"))
		return Compkiller.Debug
	end

	local function dumpStats()
		local stats = getOptimizerStats()
		local lines = {
			"+==========================================",
			"|  Compkiller v" .. Compkiller.Version .. " -- Runtime Stats",
			"+==========================================",
			"|  Hardware Tier   : " .. tostring(Compkiller.HardwareTier or "N/A"),
			"|  Hardware FPS    : " .. tostring(Compkiller.HardwareFPS  or "N/A"),
			"|  GUI Shield      : " .. tostring(Compkiller.GuiShieldMethod or "N/A"),
			"|  Performance Mode: " .. tostring(Compkiller.PerformanceMode),
			"+==========================================",
			"|  Live FPS        : " .. stats.FPS,
			"|  Anim Threshold  : " .. stats.AnimThreshold .. " fps",
			"|  Smart Anim ON   : " .. tostring(stats.Enabled),
			"|  Active Tweens   : " .. stats.ActiveTweens,
			"+==========================================",
			"|  Tweens Cancelled: " .. stats.TweensCancelled,
			"|  Instant Sets    : " .. stats.InstantSets,
			"|  Dedup Cancels   : " .. stats.DedupCancels,
			"|  Memory Sweeps   : " .. stats.MemorySweeps,
			"|  Tracked Threads : " .. #_CK_THREADS,
			"|  Tracked Conns   : " .. #_CK_CONNECTIONS,
			"|  GC Memory (KB)  : " .. tostring(math.floor((collectgarbage("count") or 0) + 0.5)),
			"+==========================================",
			"|  Windows Open    : " .. #Compkiller.Windows,
			"+==========================================",
		}
		_CKLog("dump")
		return stats
	end

	local function getVersionInfo()
		return {
			Version      = Compkiller.Version,
			HardwareTier = Compkiller.HardwareTier,
			HardwareFPS  = Compkiller.HardwareFPS,
			GuiShield    = Compkiller.GuiShieldMethod,
			PerfMode     = Compkiller.PerformanceMode,
			SmartAnim    = _OPT.Enabled,
			AnimThreshold= _OPT.AnimThreshold,
			Executor     = _CK_EXECUTOR,
			ExecVersion  = _CK_EXEC_VERSION,
			Elevated     = _CK_ELEVATED,
			MissingEnv   = _CK_MISSING_ENV,
		}
	end

	local function getExecutorProfile()
		return {
			executor   = _CK_EXECUTOR,
			version    = _CK_EXEC_VERSION,
			elevated   = _CK_ELEVATED,
			missingEnv = _CK_MISSING_ENV,
			guiShield  = _GUI_SHIELD_METHOD,
		}
	end

	local function getMissingEnv()
		return _CK_MISSING_ENV
	end

	local function isStudio()
		return RunService:IsStudio()	
	end;


	-- ========================================================================
	-- PERFORMANCE
	-- ========================================================================
	local function setPerformanceProfile(profile)
		local p = tostring(profile):upper()
		if p == "LOW" then
			Compkiller.PerformanceMode = true
			_OPT.AnimThreshold   = 60
			Compkiller.HardwareTier    = "LOW"
		elseif p == "MEDIUM" then
			Compkiller.PerformanceMode = false
			_OPT.AnimThreshold   = 40
			Compkiller.HardwareTier    = "MEDIUM"
		else
			Compkiller.PerformanceMode = false
			_OPT.AnimThreshold   = 30
			Compkiller.HardwareTier    = "HIGH"
		end
		_CKLog("SetPerformanceProfile: " .. p)
		return Compkiller.HardwareTier
	end

	local function setHardwareTier(tier)
		local valid = {HIGH = true, MEDIUM = true, LOW = true}
		tier = tostring(tier):upper()
		if not valid[tier] then
			_CKLog("SetHardwareTier: invalid tier '" .. tier .. "'. Use HIGH/MEDIUM/LOW.")
			return false
		end
		Compkiller.HardwareTier = tier
		if tier == "LOW" then
			Compkiller.PerformanceMode = true
			_OPT.AnimThreshold   = 60     -- instant-set everything
			_CKLog("SetHardwareTier: LOW | PerformanceMode=true | Threshold=60fps")
		elseif tier == "MEDIUM" then
			Compkiller.PerformanceMode = false
			_OPT.AnimThreshold   = 40
			_CKLog("SetHardwareTier: MEDIUM | PerformanceMode=false | Threshold=40fps")
		else
			Compkiller.PerformanceMode = false
			_OPT.AnimThreshold   = 30     -- default threshold
			_CKLog("SetHardwareTier: HIGH | PerformanceMode=false | Threshold=30fps")
		end
		return Compkiller.HardwareTier
	end

	local function setAnimThreshold(fps)
		_OPT.AnimThreshold = math.clamp(math.floor(fps), 10, 144)
		_CKLog("SetAnimThreshold: " .. _OPT.AnimThreshold .. " fps")
		return _OPT.AnimThreshold
	end

	local function setMemInterval(seconds)
		_OPT.MemInterval = math.max(10, seconds)
		_CKLog("SetMemInterval: " .. _OPT.MemInterval .. "s")
		return _OPT.MemInterval
	end

	local function setSleepMode(enabled)
		if enabled and not _SLEEP_ACTIVE then
			_SLEEP_ACTIVE           = true
			_SLEEP_PREV_THRESHOLD   = _OPT.AnimThreshold
			_OPT.AnimThreshold      = 999
			_OPT.Enabled            = false
			pcall(function(...) setfpscap(10) end)
			_CKLog("SetSleepMode: ON -- animations paused, FPS capped to 10.")
		elseif not enabled and _SLEEP_ACTIVE then
			_SLEEP_ACTIVE      = false
			_OPT.AnimThreshold = _SLEEP_PREV_THRESHOLD or 30
			_OPT.Enabled       = true
			pcall(function(...) setfpscap(360) end)
			_CKLog("SetSleepMode: OFF -- restored.")
		end
	end

	local function optimizeMode(v)
		Compkiller.PerformanceMode = v;
	end;

