                warn("[CK] HIGH: checkcaller missing -- all hook guards are pass-through only.")
            elseif missing == "setreadonly" or missing == "getrawmetatable" then
                warn("[CK] HIGH: " .. missing .. " missing -- metamethod guards unavailable.")
            end
        end
    end
end

