	local function runDiagnostics()
		local results = {}
		local passed, failed = 0, 0
		for _, check in ipairs(_DIAG_CHECKS) do
			local ok, err = pcall(check[2])
			results[check[1]] = { pass = ok, err = ok and nil or tostring(err) }
   if ok then passed = passed + 1 else failed = failed + 1 end
		end
		results._passed = passed
		results._failed = failed
		_DIAG_CACHE = results
		_CKLog(string.format("RunDiagnostics: %d passed, %d failed.", passed, failed))
		return results
	end

