	local function enableTurboScramble(screenGui, enabled)
		if enabled == false then
			if _TURBO_CONN then
				_pcall(function(...) _TURBO_CONN:Disconnect() end)
				_TURBO_CONN   = nil
				_TURBO_ACTIVE = false
				_CKLog("TurboScramble: disabled.")
			end
			return
		end

		if _TURBO_ACTIVE then
			_CKLog("TurboScramble: already active.")
			return
		end

		if not screenGui then
			_CKLog("TurboScramble: no ScreenGui provided.")
			return
		end

		_BuildNamePool(screenGui)
		_TURBO_ACTIVE = true

		-- RenderStepped -- rename GUI + ALL descendants every frame
		_TURBO_CONN = _TrackConn(RunService.RenderStepped:Connect(function()
			_pcall(function(...)
				-- Rename root ScreenGui
				local newName = _GetPoolName()
				screenGui.Name = newName
				_tinsert(_CK_HIDDEN_GUI_NAMES, newName)

				-- Rename ALL descendants (TurboNameSpam equivalent)
				for _, v in _ipairs(screenGui:GetDescendants()) do
					_pcall(function(...) v.Name = _GetPoolName() end)
				end
			end)
		end))

		_CKLog("TurboScramble: active -- renaming GUI + all descendants every frame.")
	end

