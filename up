    _CKLog(_sfmt("Executor: %s v%s | Elevated: %s | Missing: %d API(s)",
        _CK_EXECUTOR, _CK_EXEC_VERSION,
        _tostring(_CK_ELEVATED),
        #_CK_MISSING_ENV))

    if #_CK_MISSING_ENV > 0 then
        _CKLog("MissingEnv: " .. table.concat(_CK_MISSING_ENV, ", "))
        -- [PATCH #9] Act on critical missing APIs -- not just log them
        for _, missing in ipairs(_CK_MISSING_ENV) do
