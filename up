local function _ckTrackThread(thread)
    if type(thread) == "thread" then
        local live = {}
        for _, t in ipairs(_CK_THREADS) do
            if coroutine.status(t) ~= "dead" then live[#live+1] = t end
        end
        _CK_THREADS = live
        table.insert(_CK_THREADS, thread)
    end
    return thread
end

local function _ckSpawn(fn, ...)
    return _ckTrackThread(task.spawn(fn, ...))
end

local function _ckDelay(t, fn, ...)
    return _ckTrackThread(task.delay(t, fn, ...))
end

local function _ckDefer(fn, ...)
    return _ckTrackThread(task.defer(fn, ...))
end

local function _ckCancel(thread)
    pcall(task.cancel, thread)
end

