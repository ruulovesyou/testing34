                    elseif tbl[1] == game then
                        return _CONTENT_FN_HOOK(self, _shuffleTable(table.move(_GAME_ASSETS,1,#_GAME_ASSETS,1,{})), cb)
                    end
                end
                return _CONTENT_FN_HOOK(self, tbl, cb)
            end))
        end

        _CONTENT_ACTIVE = true
        _CKLog("ContentBypass: PreloadAsync intercept active.")
    end

    function Compkiller:EnableContentBypass(enabled)
        if enabled == false then
            _CONTENT_ACTIVE = false
