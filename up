        screenGui.Name = encName
        _tinsert(_CK_HIDDEN_GUI_NAMES, encName)
        _CKLog("GuiEncrypt: renamed -> " .. encName)
    end)

    -- Try every known protect_gui variant (Synapse, KRNL, Fluxus, Delta, etc.)
    -- islclosure guard: if protect_gui is a Lua closure it may have been hooked/replaced
    -- In that case skip it and fall back to gethui directly (darkdex technique)
    _pcall(function(...)
        local protectFns = {
            protect_gui,
            protectgui,
            syn and syn.protect_gui,
            fluxus and fluxus.protect_gui,
            getgenv and getgenv().protect_gui,
        }
        local fnNames = {
            "protect_gui", "protectgui", "syn.protect_gui",
            "fluxus.protect_gui", "getgenv().protect_gui",
        }
        for i, fn in _ipairs(protectFns) do
            if _type(fn) == "function" then
                -- Skip if it's a Lua closure -- likely hooked by a game AC
                if _islclosure(fn) then
                    _CKLog("GuiShield: " .. (fnNames[i] or "?") .. " is islclosure -- skipped (may be hooked).")
                    -- Do NOT break -- keep trying next candidate
                else
                    _newcclosure(fn)(screenGui)
                    _CKLog("GuiShield: protect_gui applied via " .. (fnNames[i] or "?"))
                    break
                end
            end
        end
        -- Last-resort fallback: use gethui directly if all protect fns were Lua closures
        if not screenGui.Parent or screenGui.Parent ~= _GUI_PARENT then
            local huiFn = gethui or get_hidden_ui or get_hidden_gui or hiddenUI
            if _type(huiFn) == "function" and not _islclosure(huiFn) then
                local ok, hui = _pcall(huiFn)
                if ok and hui then
                    _pcall(function(...) screenGui.Parent = hui end)
                    _CKLog("GuiShield: gethui fallback used -- protect_gui candidates were all Lua closures.")
                end
            end
        end
    end)

    -- Set parent
    _pcall(function(...) screenGui.Parent = _GUI_PARENT end)

    -- Tag with hidden attribute
    _pcall(function(...) screenGui:SetAttribute(_CK_GUI_TAG, true) end)

    -- Start integrity monitor
    _pcall(function(...) _StartGuiIntegrityMonitor(screenGui) end)

    -- Install __namecall hook on the ScreenGui's metatable to block Destroy calls
    _pcall(function(...)
        local sgmt = _getrawmetatable(screenGui)
        if not sgmt then return end
        local oldNC = sgmt.__namecall
        if not oldNC then return end

        _setreadonly(sgmt, false)
        sgmt.__namecall = _newcclosure(function(self, ...)
            -- Let executor's own calls through
            if _checkcaller() then return oldNC(self, ...) end
            local method = _getnamecallmethod()
            -- Block game-side attempts to Destroy or re-parent our ScreenGui
            if self == screenGui and (method == "Destroy" or method == "Remove") then
                _CKLog("GuiShield: blocked game-side :" .. method .. "() on ScreenGui.")
                return nil
            end
            return oldNC(self, ...)
        end)
        _setreadonly(sgmt, true)
        _CKLog("GuiShield: __namecall Destroy-block installed on ScreenGui.")
    end)
end

