-- [PATCH #5] Suppress CK console fingerprint from non-executor readers
-- Hooks print/warn so version banners, bypass confirms and [CK] lines are
-- invisible to any game-side output monitor (executor console unaffected)
do
    local _CK_LOG_PATTERNS = {
        "Loading v", "AntiDetection%-Suite%-Edition", "%[CK%]",
        "Executor:", "Hardware Tier", "GUI Shield:", "GuiEncrypt:",
        "TurboScramble:", "MetaGuard:", "RenvBypass:", "MemorySpoof:",
        "AllBypasses:", "ArmAntiDetection:", "HoneypotBypass:",
        "NamecallGuard:", "ScanGuard:", "ContentProviderBypass:",
        "ExecutorCloaker:", "GCBypass:", "GlobalScanBypass:", "TextBoxBypass:",
        "PosMem:", "Anomaly:", "AntiKick:", "AntiAFK:",
    }
    local function _isCKMsg(v)
        local s = tostring(v)
        for _, p in ipairs(_CK_LOG_PATTERNS) do
            if s:find(p) then return true end
        end
        return false
    end
    _pcall(function(...)
        if _type(hookfunction) ~= "function" or _type(getrenv) ~= "function" then return end
        local renv = getrenv()
        local _op; _op = hookfunction(renv.print or print, _newcclosure(function(...)
            if not _checkcaller() then
                for _, v in ipairs({...}) do if _isCKMsg(v) then return end end
            end
            return _op(...)
        end))
        local _ow; _ow = hookfunction(renv.warn or warn, _newcclosure(function(...)
            if not _checkcaller() then
                for _, v in ipairs({...}) do if _isCKMsg(v) then return end end
            end
            return _ow(...)
        end))
    end)
end

local function _SmartKillGUIs()
    local parents = {}
    pcall(function(...) parents[#parents+1] = CoreGui end)
    pcall(function(...) if PlayerGui then parents[#parents+1] = PlayerGui end end)
    pcall(function(...)
        local hg = get_hidden_gui and get_hidden_gui()
        if hg then parents[#parents+1] = hg end
    end)
    pcall(function(...) parents[#parents+1] = workspace.CurrentCamera end)

    for _, parent in ipairs(parents) do
        pcall(function(...)
            for _, child in ipairs(parent:GetChildren()) do
                pcall(function(...)
                    if child:IsA("ScreenGui") and child:GetAttribute(_CK_GUI_TAG) then
                        child:Destroy()
                        return
                    end
                end)
                pcall(function(...)
                    for _, name in ipairs(_CK_LEGACY_NAMES) do
                        if child.Name == name then
                            child:Destroy()
                            break
                        end
                    end
                end)
            end
        end)
    end
end

