-- [PATCH #4] Boot race detector -- warn if key globals were pre-hooked
-- before CK loaded (means captured originals may be compromised)
do
    local _bootRaceCheck = { pcall = pcall, rawget = rawget, rawset = rawset,
                              tostring = tostring, type = type, pairs = pairs }
    for name, fn in pairs(_bootRaceCheck) do
        if (islclosure or is_l_closure or function() return false end)(fn) then
            warn("[CK] BOOT-RACE: " .. name .. " is a Lua closure -- captured original may be hooked.")
        end
    end
end

-- SYN SHIM -- if executor has no syn table at all, build a minimal one
do
    -- Resolve hidden UI function across all known executor aliases
    local _huiFn = gethui or get_hidden_ui or get_hidden_gui or hiddenUI or nil

    -- [PATCH #3] Pre-create syn silently so the global write happens inside
    -- a protected context -- avoids triggering __newindex watchers on _G
    _pcall(function(...)
        if not rawget(_G, "syn") then
            rawset(_G, "syn", {})
        end
    end)
    if not syn then
        syn = {}
    end
    -- Build protect_gui shim if executor has none
    if not syn.protect_gui then
        if _huiFn then
            syn.protect_gui = function(obj)
                _pcall(function(...) obj.Parent = _huiFn() end)
            end
        elseif protect_gui or protectgui then
            syn.protect_gui = protect_gui or protectgui
        end
    end
    -- Expose get_hidden_gui under syn too if missing
    if not syn.get_hidden_gui and _huiFn then
        syn.get_hidden_gui = _huiFn
    end
end

