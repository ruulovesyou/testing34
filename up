	local function forceGC()
		local before = math.floor((collectgarbage("count") or 0) + 0.5)
		collectgarbage("collect")
		local after  = math.floor((collectgarbage("count") or 0) + 0.5)
		local freed  = math.max(0, before - after)
		_CKLog(string.format("ForceGC: freed ~%d KB (before=%d, after=%d)", freed, before, after))
		return freed
	end

	local function cleanupAll()
		local cancelled = 0
		for key, tw in pairs(_OPT.ActiveTweenMap) do
			local ok, playing = pcall(function(...) return tw.PlaybackState end)
			if ok and playing == Enum.PlaybackState.Playing then
				pcall(function(...) tw:Cancel() end)
				cancelled = cancelled + 1
			end
			_OPT.ActiveTweenMap[key] = nil
		end
		for _, tw in ipairs(_OPT.ActiveTweens) do
			local ok, playing = pcall(function(...) return tw.PlaybackState end)
			if ok and playing == Enum.PlaybackState.Playing then
				pcall(function(...) tw:Cancel() end)
				cancelled = cancelled + 1
			end
		end
		_OPT.ActiveTweens = {}
		_OPT.Stats.TweensCancelled = _OPT.Stats.TweensCancelled + cancelled
		Compkiller:_SweepMemory()
		_CKLog("CleanupAll: cancelled " .. cancelled .. " tweens.")
		return cancelled
	end


	-- ========================================================================
	-- RENDER MANAGER
	-- ========================================================================
	local function startRenderManager()
		stopRenderManager()

		local conns = {}

		local c1 = _TrackConn(UserInputService.WindowFocusReleased:Connect(function()
			if not getgenv()[_CULL_KEY] then
				getgenv()[_CULL_KEY] = _SaveCameraState()
			end
			_SuppressRender()
			_CKLog("RenderManager: focus lost -- 3D suppressed, FPS capped.")
		end))
		table.insert(conns, c1)

		local c2 = _TrackConn(UserInputService.WindowFocused:Connect(function()
			local state = getgenv()[_CULL_KEY]
			if state then
				_RestoreRender(state)
				getgenv()[_CULL_KEY] = nil
			end
			_CKLog("RenderManager: focus gained -- 3D restored.")
		end))
		table.insert(conns, c2)

		getgenv()[_RENDER_CONN] = conns
		_CKLog("StartRenderManager: active.")
	end

	local function stopRenderManager()
		local state = getgenv()[_CULL_KEY]
		if state then
			_RestoreRender(state)
			getgenv()[_CULL_KEY] = nil
		end
		local conns = getgenv()[_RENDER_CONN]
		if type(conns) == "table" then
			for _, c in ipairs(conns) do
				pcall(function(...) c:Disconnect() end)
			end
		end
		getgenv()[_RENDER_CONN] = nil
		_CKLog("StopRenderManager: stopped, 3D restored.")
	end

	local function renderCull()
		if getgenv()[_CULL_KEY] then
			_CKLog("RenderCull: already active.")
			return
