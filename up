-- BYPASS ENGINE -- AC bypass systems (AntiCheat.txt detections -> defeated)
--         CoreGui weak-ref honey pot, DescendantAdded scanner, executor global scan,
--         metamethod tamper detector, newproxy GC trap, suspicious globals scan
do

    -- SHARED UTILS
    local _RunService     = cloneref(game:GetService("RunService"))
    local _Stats          = cloneref(game:GetService("Stats"))
    local _ContentProv    = cloneref(game:GetService("ContentProvider"))
    local _CoreGuiSvc     = cloneref(game:GetService("CoreGui"))
    local _UserInput      = cloneref(game:GetService("UserInputService"))
    local _cos            = math.cos
    local _acos           = math.acos
    local _pi             = math.pi
    local _rand           = Random.new()

    -- [BYPASS 1] gcinfo / collectgarbage SPOOF
    -- Detection: game reads gcinfo() or collectgarbage("count") and compares over time.
    -- Bypass: hook both with a realistic cosine-wave oscillating value so it looks
    --         like real GC activity instead of a flat/static exploit memory signature.
    local _GCINFO_ACTIVE      = false
    local _GCINFO_HOOK1       = nil
    local _GCINFO_HOOK2       = nil
    local _GCINFO_TICK_CONN   = nil

    local function _EnableGCBypass()
        if _GCINFO_ACTIVE then return end
        if _type(hookfunction) ~= "function" or _type(getrenv) ~= "function" then
            _CKLog("GCBypass: hookfunction/getrenv unavailable -- skipped.")
            return
        end

        local Amplitude   = 200
        local _wave_tick  = 0
        local OldGcInfo   = gcinfo() + Amplitude

        local function _wave()
            local f = math.abs(math.sin(math.pi * _wave_tick)) * Amplitude * 2 - Amplitude
            return _mfloor(OldGcInfo + f)
        end

        _GCINFO_TICK_CONN = _TrackConn(_RunService.Stepped:Connect(function()
            _wave_tick = _wave_tick + 0.03
            if _wave_tick > 1 then _wave_tick = _wave_tick - 1 end
        end))

        _pcall(function(...)
            _GCINFO_HOOK1 = hookfunction(getrenv().gcinfo, _newcclosure(function(...)
                return _wave()
            end))
        end)

        _pcall(function(...)
            _GCINFO_HOOK2 = hookfunction(getrenv().collectgarbage, _newcclosure(function(arg, ...)
