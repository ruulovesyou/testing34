-- AntiKick -- blocks all kick methods targeting LocalPlayer
-- Method 1: hookfunction directly on LocalPlayer.Kick
-- Method 2: hookmetamethod on LocalPlayer __namecall + setreadonly + checkcaller
-- Method 3: hookmetamethod on game __namecall + setreadonly + checkcaller
-- Method 4: getrawmetatable fallback (no hookmetamethod needed)
do
    local _ANTIKICK_ORIG_KICK  = nil
    local _ANTIKICK_ORIG_NCI   = nil
    local _ANTIKICK_ORIG_NCG   = nil
    local _ANTIKICK_ACTIVE     = false

    function Compkiller:EnableAntiKick(enabled)

        -- DISABLE
        if enabled == false then
            if not _ANTIKICK_ACTIVE then return end

            if _ANTIKICK_ORIG_KICK and _type(hookfunction) == "function" then
                _pcall(function(...) hookfunction(LocalPlayer.Kick, _ANTIKICK_ORIG_KICK) end)
            end
            if _ANTIKICK_ORIG_NCI and _type(hookmetamethod) == "function" then
                _pcall(function(...) hookmetamethod(LocalPlayer, "__namecall", _ANTIKICK_ORIG_NCI) end)
            end
            if _ANTIKICK_ORIG_NCG and _type(hookmetamethod) == "function" then
                _pcall(function(...) hookmetamethod(game, "__namecall", _ANTIKICK_ORIG_NCG) end)
            end

            _ANTIKICK_ORIG_KICK = nil
            _ANTIKICK_ORIG_NCI  = nil
            _ANTIKICK_ORIG_NCG  = nil
            _ANTIKICK_ACTIVE    = false
            _CKLog("AntiKick: disabled -- originals restored.")
            return
        end

        if _ANTIKICK_ACTIVE then
            _CKLog("AntiKick: already active.")
            return
        end

        -- METHOD 1: hookfunction on LocalPlayer.Kick
        if _type(hookfunction) == "function" then
            _pcall(function(...)
                _ANTIKICK_ORIG_KICK = hookfunction(
                    LocalPlayer.Kick,
                    _newcclosure(function(...) end)
                )
                _CKLog("AntiKick [M1]: hookfunction on LocalPlayer.Kick.")
            end)
        end

        -- METHOD 2: hookmetamethod on LocalPlayer __namecall
        -- Exact pattern with checkcaller() guard + setreadonly bracket
        if _type(hookmetamethod) == "function" then
            _pcall(function(...)
                _ANTIKICK_ORIG_NCI = hookmetamethod(
                    LocalPlayer,
                    "__namecall",
                    _newcclosure(function(self, ...)
                        if _checkcaller() then return _ANTIKICK_ORIG_NCI(self, ...) end
                        local _ck_method = _getnamecallmethod()
                        if self == LocalPlayer and (_ck_method == "Kick" or _ck_method == "KickToSelect") then
                            _CKLog("AntiKick [M2]: blocked :" .. _ck_method .. "() on LocalPlayer.")
                            return nil
                        end
                        return _ANTIKICK_ORIG_NCI(self, ...)
                    end)
                )
                _CKLog("AntiKick [M2]: hookmetamethod on LocalPlayer.__namecall.")
            end)
        end

        -- METHOD 3: hookmetamethod on game __namecall
        if _type(hookmetamethod) == "function" then
            _pcall(function(...)
                _ANTIKICK_ORIG_NCG = hookmetamethod(
                    game,
                    "__namecall",
                    _newcclosure(function(self, ...)
                        if _checkcaller() then return _ANTIKICK_ORIG_NCG(self, ...) end
                        if _getnamecallmethod() == "Kick"
                        and (self == LocalPlayer or self == Players.LocalPlayer) then
                            _CKLog("AntiKick [M3]: blocked game-level :Kick().")
                            return nil
                        end
                        return _ANTIKICK_ORIG_NCG(self, ...)
                    end)
                )
                _CKLog("AntiKick [M3]: hookmetamethod on game.__namecall.")
            end)
        end

        -- METHOD 4: getrawmetatable fallback (CMD X pattern)
        -- Used when hookmetamethod is unavailable -- direct metatable write
        if _type(hookmetamethod) ~= "function" and _type(_getrawmetatable) == "function" then
            _pcall(function(...)
                local mt    = _getrawmetatable(game)
                if not mt then return end
                local oldNC = mt.__namecall
                if not oldNC then return end

                _setreadonly(mt, false)
                mt.__namecall = _newcclosure(function(self, ...)
                    if _checkcaller() then return oldNC(self, ...) end
                    if _getnamecallmethod() == "Kick"
                    and (self == LocalPlayer or self == Players.LocalPlayer) then
                        _CKLog("AntiKick [M4]: blocked via rawmetatable.")
                        return nil
                    end
                    return oldNC(self, ...)
                end)
                _setreadonly(mt, true)
                _ANTIKICK_ORIG_NCG = oldNC   -- store so disable can restore
                _CKLog("AntiKick [M4]: getrawmetatable fallback applied.")
            end)
        end

        _ANTIKICK_ACTIVE = true
        _CKLog("AntiKick: all available methods applied.")
    end
end


do
    -- JANITOR -- tracks connections, instances, threads, and functions
    local Janitor = {}
    Janitor.__index = Janitor

    function Janitor.new()
        return setmetatable({ _items = {} }, Janitor)
    end

    function Janitor:Add(connection)
        _tinsert(self._items, { type = "conn", ref = connection })
        return connection
    end

    function Janitor:AddInstance(instance)
        _tinsert(self._items, { type = "inst", ref = instance })
        return instance
    end

    function Janitor:AddFn(fn)
        _tinsert(self._items, { type = "fn", ref = fn })
        return fn
    end

    -- NEW: track a spawned thread for cleanup
    function Janitor:AddThread(thread)
        _tinsert(self._items, { type = "thread", ref = thread })
        return thread
    end

    -- NEW: one-liner helper -- spawn + track in one call
    function Janitor:Spawn(fn, ...)
        local t = _ckSpawn(fn, ...)
        return self:AddThread(t)
    end

    function Janitor:Destroy()
        for _, item in _ipairs(self._items) do
            _pcall(function(...)
                if item.type == "conn" then
                    item.ref:Disconnect()
                elseif item.type == "inst" then
                    item.ref:Destroy()
                elseif item.type == "fn" then
                    item.ref()
                elseif item.type == "thread" then
                    task.cancel(item.ref)
                end
            end)
        end
        self._items = {}
    end

    function Compkiller:NewJanitor()
        return Janitor.new()
    end
end


