-- ============================================================================
--  EXECUTOR COMPATIBILITY SHIM  --  normalises environment BEFORE anything runs
--  Supports: Synapse X, Synapse V3, KRNL, Fluxus, Delta, Solara, Electron,
--            Celery, Nihon, Comet, Velocity, Hydrogen, Arceus X, and others.
-- ============================================================================
do
    -- -- unpack (table.unpack is Lua 5.2+, some executors only have global unpack) --
    if type(table.unpack) ~= "function" then
        table.unpack = unpack
    end

    -- -- task library ---------------------------------------------------------
    -- Older executors expose spawn/delay/wait at global scope, not task.*
    if type(task) ~= "table" then
        task = {}
    end
    if type(task.spawn) ~= "function" then
        task.spawn = function(fn, ...)
            local args = {...}
            local co = coroutine.wrap(function() fn((table.unpack or unpack)(args)) end)
            local ok, err = pcall(co)
            if not ok then warn("[CK:task.spawn] " .. tostring(err)) end
        end
    end
    if type(task.wait) ~= "function" then
        task.wait = (type(wait) == "function" and wait)
            or function(n)
                local start = tick()
                repeat coroutine.yield() until tick() - start >= (n or 0)
            end
    end
    if type(task.delay) ~= "function" then
        task.delay = function(t, fn, ...)
            local args = {...}
            task.spawn(function(...) task.wait(t) fn((table.unpack or unpack)(args)) end)
        end
    end
    if type(task.defer) ~= "function" then
        task.defer = task.spawn
    end
    if type(task.cancel) ~= "function" then
        task.cancel = function(co)
            pcall(function(...)
                if type(co) == "thread" and coroutine.status(co) ~= "dead" then
                    coroutine.resume(co)
                end
            end)
        end
    end

    -- -- getgenv / getrenv -----------------------------------------------------
    -- Hydrogen, Arceus X, Velocity and others don't always expose these
    if type(getgenv) ~= "function" then
        local _genv = {}
        getgenv = function() return _genv end
    end
    if type(getrenv) ~= "function" then
        getrenv = function() return {} end
    end

    -- -- coroutine.close -------------------------------------------------------
    -- Not available in Lua 5.1 environments used by some executors
    if type(coroutine.close) ~= "function" then
        coroutine.close = function(co)
            pcall(function(...)
                if coroutine.status(co) == "suspended" then
                    coroutine.resume(co)
                end
            end)
        end
    end

    -- -- typeof ----------------------------------------------------------------
    if type(typeof) ~= "function" then
        typeof = type
    end

    -- -- warn ------------------------------------------------------------------
    if type(warn) ~= "function" then
        warn = print
    end

    -- -- cloneref -------------------------------------------------------------
    if type(cloneref) ~= "function" then
        cloneref = function(obj) return obj end
    end

    -- -- gethui / protect_gui --------------------------------------------------
    if type(gethui) ~= "function" then
        gethui = get_hidden_ui or get_hidden_gui or hiddenUI
            or function() return game:GetService("CoreGui") end
    end
    if type(protect_gui) ~= "function" then
        protect_gui = (type(syn) == "table" and syn.protect_gui) or function() end
    end

    -- -- hook functions -- nil is safer than a stub so CK type() checks work --
    if type(hookfunction)    ~= "function" then hookfunction    = nil end
    if type(hookmetamethod)  ~= "function" then hookmetamethod  = nil end

    -- -- newcclosure -----------------------------------------------------------
    if type(newcclosure) ~= "function" then
        newcclosure = function(f) return f end
    end

    -- -- metamethod/env helpers ------------------------------------------------
    if type(setreadonly) ~= "function" then
        setreadonly = function() end
    end
    if type(getrawmetatable) ~= "function" then
        getrawmetatable = function(t)
            return debug and type(debug.getmetatable) == "function"
                and debug.getmetatable(t) or nil
        end
    end
    if type(checkcaller) ~= "function" then
        checkcaller = function() return true end  -- assume executor = safe caller
    end
    if type(getnamecallmethod) ~= "function" then
        getnamecallmethod = function() return "" end
    end
    if type(identifyexecutor) ~= "function" then
        identifyexecutor = what_is_my_executor or function() return "unknown", "0" end
    end
    if type(islclosure) ~= "function" then
        islclosure = is_l_closure or function() return false end
    end
    if type(isourclosure) ~= "function" then
        isourclosure = is_our_closure or function() return false end
    end
    if type(getconnections) ~= "function" then
        getconnections = function() return {} end
    end
    if type(setfpscap) ~= "function" then
        setfpscap = function() end
    end
    if type(ficloseupvalue) ~= "function" then
        ficloseupvalue = function() end
    end
    if type(getupvalues) ~= "function" then
        getupvalues = function() return {} end
    end
    -- File system APIs
    if type(isfile) ~= "function" then isfile = function() return false end end
    if type(isfolder) ~= "function" then isfolder = function() return false end end
    if type(readfile) ~= "function" then readfile = function() return "" end end
    if type(writefile) ~= "function" then writefile = function() end end
    if type(makefolder) ~= "function" then makefolder = function() end end
    if type(listfiles) ~= "function" then listfiles = function() return {} end end
    if type(getcustomasset) ~= "function" and type(getsynasset) ~= "function" then
        getcustomasset = function() return "" end
    end
end
