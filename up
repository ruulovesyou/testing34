    local _MEM_ACTIVE     = false
    local _MEM_HOOK1      = nil
    local _MEM_HOOK2      = nil
    local _MEM_HOOK3      = nil
    local _MEM_HOOK4      = nil
    local _MEM_NC_HOOK    = nil
