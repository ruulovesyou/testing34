		return _DIAG_CACHE
	end

	local function startAnomalyDetector(interval)
		if _DETECTOR_THREAD then
			_CKLog("Anomaly: detector already running.")
			return
		end
		interval = _mmax(2, interval or 5)
		_BASELINE = _captureBaseline()
		_CKLog(_sfmt("Anomaly: baseline captured (%d targets), scanning every %ds.",
			#_WATCH, interval))

		_DETECTOR_THREAD = _ckSpawn(function(...)
			while _DETECTOR_THREAD do
				task.wait(interval)
				if not _DETECTOR_THREAD then break end

				local tampered = {}
				for _, w in _ipairs(_WATCH) do
					local ok, cur = _pcall(_rawget, w[1], w[2])
					if ok and _BASELINE[w[3]] ~= nil and cur ~= _BASELINE[w[3]] then
						_tinsert(tampered, w[3])
					end
				end

				-- Hook detection pass
				local hooked = _detectHooks()
				for _, h in _ipairs(hooked) do
					_tinsert(tampered, h)
				end

				if #tampered > 0 then
					warn("[CK:Anomaly] (!) Tampered/Hooked: " .. table.concat(tampered, ", "))
					if _type(_TAMPER_CALLBACK) == "function" then
						_pcall(_TAMPER_CALLBACK, tampered)
					end
				else
					_CKLog("Anomaly: scan clean.")
				end
			end
		end)
	end

	local function stopAnomalyDetector()
		if _DETECTOR_THREAD then
			_pcall(task.cancel, _DETECTOR_THREAD)
			_DETECTOR_THREAD = nil
			_BASELINE        = nil
			_CKLog("Anomaly: detector stopped.")
		end
	end

	local function setAnomalyCallback(fn)
		-- [PATCH #7] Wrap callback in pcall so a crash cannot kill the detector loop
		if _type(fn) == "function" then
			_TAMPER_CALLBACK = function(...)
				local ok, err = _pcall(fn, ...)
				if not ok then
					_CKLog("Anomaly: callback error (loop preserved): " .. _tostring(err))
				end
			end
		else
			_TAMPER_CALLBACK = nil
		end
		_CKLog("Anomaly: callback " .. (_TAMPER_CALLBACK and "set (sandboxed)." or "cleared."))
	end

	local function runAnomalyCheck()
		local tampered = {}
		local clean    = {}
		for _, w in _ipairs(_ANOMALY_WATCH) do
			local ok, cur = _pcall(_rawget, w[1], w[2])
			if ok and _BASE_SNAP[w[3]] ~= nil and cur ~= _BASE_SNAP[w[3]] then
				_tinsert(tampered, w[3])
			else
				_tinsert(clean, w[3])
			end
		end
		-- Hook presence check
		if _type(hookfunction)   == "function" then _tinsert(tampered, "hookfunction_present")   end
		if _type(hookmetamethod) == "function" then _tinsert(tampered, "hookmetamethod_present") end
		_ANOMALY_REPORT = {
			tampered  = tampered,
			clean     = clean,
			checkedAt = _tick(),
			safe      = (#tampered == 0),
		}
		_CKLog(_sfmt("RunAnomalyCheck: %d tampered, %d clean.", #tampered, #clean))
		return _ANOMALY_REPORT
	end

	local function getAnomalyReport()
		if not _ANOMALY_REPORT then
			return runAnomalyCheck()
		end
		return _ANOMALY_REPORT
	end

	local function runExecutorIntegrityTest()
		local results = {}
		local passed  = 0
		local failed  = 0

		for _, probe in _ipairs(_PROBES) do
			local ok, err = _pcall(probe.fn)
			results[probe.name] = {
				pass  = ok,
				desc  = probe.desc,
				err   = ok and nil or _tostring(err),
			}
			if ok then
				passed = passed + 1
				_CKLog(_sfmt("IntegrityProbe [[ok]] %s", probe.name))
			else
				failed = failed + 1
				warn(_sfmt("[CK:Integrity] [x] %s -- %s", probe.name, _tostring(err)))
			end
		end

		_INTEGRITY_REPORT = {
			passed    = passed,
			failed    = failed,
			total     = passed + failed,
			safe      = (failed == 0),
			results   = results,
			testedAt  = _tick(),
		}

		_CKLog(_sfmt("IntegrityTest: %d/%d passed -- executor %s.",
			passed, passed + failed,
			failed == 0 and "appears CLEAN" or "has SUSPICIOUS traits"))

		return _INTEGRITY_REPORT
	end

	local function getIntegrityReport()
		if not _INTEGRITY_REPORT then
			return runExecutorIntegrityTest()
		end
		return _INTEGRITY_REPORT
	end


