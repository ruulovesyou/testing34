				v.Element[v.Property] = Compkiller.Colors.Highlight;
			end;
		end;

		for i,v in next , Compkiller.Elements do
			if v.Element and v.Property and v.Element:GetAttribute('Enabled') then
				v.Element[v.Property] = Compkiller.Colors.Highlight;
			end;
